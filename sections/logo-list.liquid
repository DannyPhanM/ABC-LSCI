{
"value": "left_right",
"label": "t:sections.scrolling-bar.settings.marq_direction.options__1.label"
},
{
"value": "right_left",
"label": "t:sections.scrolling-bar.settings.marq_direction.options__2.label"
}
],
"default": "right_left"
},

{
"type": "range",
"id": "change_slides_speed",
"min": 3,
"max": 9,
"step": 1,
"unit": "s",
"label": "t:sections.slideshow.settings.change_slides_speed.label",
"info": "t:sections.slideshow.settings.change_slides_speed.infor",
"default": 4
