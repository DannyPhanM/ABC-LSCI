{{ 'social-media-list.css' | asset_url | stylesheet_tag }}
{%- style -%}
.section-{{ section.id }}-padding .section-head strong, .section-{{ section.id }}-padding .section-head b {
  color: {{ section.settings.headcolor }};
}
.section-{{ section.id }}-padding .topc strong, .section-{{ section.id }}-padding .topc b {
  color: {{ section.settings.headcolor1 }};
}
.section-{{ section.id }}-padding .topc {
  font-size: calc(var(--font-body-scale) * 16px);
  font-weight: 500;
}
.section-{{ section.id }}-padding .topc a {
  text-decoration: none;
}
.section-{{ section.id }}-padding .social_usermain {
  background-color: rgba(var(--color-background),{{ section.settings.social_bg_opacity | divided_by: 100.0 }});
}
.section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.45 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.45 | round: 0 }}px;
}
@media screen and (min-width: 992px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
{%- endstyle -%}

<div class="social_image color-{{ section.settings.color_scheme }} isolate gradient simg-{{ section.settings.sociald_style }}">
  <div class="section-{{ section.id }}-padding {% if section.settings.layout == 'full_width' %}section-full {% else %}page-width{% endif %}">
    {%- if section.settings.title != blank -%}
      <div class="section-head-top {{ section.settings.heading_position }}">
        <div>
          <h2 class="section-head inline-richtext {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            {{ section.settings.title }}
          </h2>
        </div>
        {%- if section.settings.view_label != blank -%}
          <div class="topc collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
            <span>{{ section.settings.view_label }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}
    <div class="social_right_img">
      <slider-carousel data-breakpoints='{ "0": 2, "m-576": 2, "768": {{ section.settings.columns_desktop }} }' data-spacing-grid-horizontal='{{ settings.spacing_grid_horizontal }}' data-section-setting='{{ section.settings | json }}'>
        <div class="swiper swipesocial {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <div class="{% if section.settings.display_type == 'carousel' %}swiper-wrapper {% endif %} grid  grid--{{ section.settings.columns_desktop }}-col">
            {%- for block in section.blocks -%}
              {%- liquid
                assign ratio = 1
                if block.settings.image and section.settings.image_ratio == 'portrait'
                  assign ratio = 0.8
                elsif block.settings.image and section.settings.image_ratio == 'adapt'
                  assign ratio = block.settings.image.aspect_ratio
                endif
                if ratio == 0 or ratio == null
                  assign ratio = 1
                endif
              -%}
              <div class="grid__item {% if section.settings.display_type == 'carousel' %}swiper-slide{% endif %} center">
                {% if block.settings.image != blank %}
                <div class="ratio social_story" style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;">
                  <div class="media">
                    <img loading="lazy"
                    srcset="
                    {%- if block.settings.image.width >= 375 -%}{{ block.settings.image | image_url: width: 375 }} 375w,{%- endif -%}
                    {%- if block.settings.image.width >= 750 -%}{{ block.settings.image | image_url: width: 750 }} 750w,{%- endif -%}
                    {%- if block.settings.image.width >= 1100 -%}{{ block.settings.image | image_url: width: 1100 }} 1100w,{%- endif -%}
                    {%- if block.settings.image.width >= 1500 -%}{{ block.settings.image | image_url: width: 1500 }} 1500w,{%- endif -%}
                    {%- if block.settings.image.width >= 1780 -%}{{ block.settings.image | image_url: width: 1780 }} 1780w,{%- endif -%}
                    {%- if block.settings.image.width >= 2000 -%}{{ block.settings.image | image_url: width: 2000 }} 2000w,{%- endif -%}
                    {%- if block.settings.image.width >= 3000 -%}{{ block.settings.image | image_url: width: 3000 }} 3000w,{%- endif -%}
                    {%- if block.settings.image.width >= 3840 -%}{{ block.settings.image | image_url: width: 3840 }} 3840w,{%- endif -%}
                    {{ block.settings.image | image_url }} {{ block.settings.image.width }}w"
                    src="{{ block.settings.image | image_url: width: 1500 }}"
                    class="img-fluid mx-auto lazyload"
                    sizes="100vw"
                    alt="{{ block.settings.image.alt }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}">
                    
                      <a {% if block.settings.social_link == blank %} role="link" aria-disabled="true" {% else %} href="{{ block.settings.social_link }}" {% endif %} class="insta_link" title="icon" {{ block.shopify_attributes }}>
                        <span>{% render 'icon-instagram' %}</span>
                      </a>
                    
                    
                      {% if section.settings.sociald_style == 'sociald_style3' %}
                        <div class="social_usermain color-{{ section.settings.social_color_scheme }} gradient">
                          <div class="social_user">
                            <div class="{{ section.settings.user_image_shape }}">
                              {% if section.settings.insta_img != blank %}
                                <img class="img-fluid lazyload"
                                  src="{{ section.settings.insta_img | image_url: width: 40 }}"
                                  width="40"
                                  height="40"
                                  alt="{{ section.settings.insta_img.alt | escape }}"
                                  loading="lazy"/>
                              {% else %}
                                <div class="dummy_user">{% render 'icon-instagram' %}</div>
                              {% endif %}
                            </div>
                            {%- if section.settings.user_name != blank -%}
                              <div class="social_name">{{ section.settings.user_name }}</div>
                            {%- endif -%}
                          </div>
                          {%- if section.settings.button_label != blank -%}
                            <a {% if block.settings.social_link == blank %}role="link" aria-disabled="true" {% else %}href="{{ block.settings.social_link }}" {% endif %} class="social_btn link">
                              {% render 'icon-instagram' %}{{- section.settings.button_label | escape -}}
                            </a>
                          {%- endif -%}
                        </div>
                      {% endif %}

                  </div>
                </div>
                {% else %}
                {% liquid
                  assign ridx = forloop.rindex
                  if ridx == 5 or ridx == 9
                    assign ridx = 1
                  endif
                  if  ridx == 6 or ridx == 10
                    assign ridx = 2
                  endif
                  if  ridx == 7
                    assign ridx = 3
                  endif
                  if  ridx == 8
                    assign ridx = 4
                  endif
                %}
                {%- assign placeholder_image = 'product-apparel-' | append: ridx -%}
                <div class="ratio social_story" style="--ratio-percent: 100%;">
                  <div class="media">
                    <div class="dummysvg">
                      {%- if placeholder_image -%}
                        {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                      {%- else -%}
                        {{ 'product-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>
                    {%- if block.settings.social_link != blank -%}
                      <a href="{{ block.settings.social_link }}" class="insta_link" title="icon" {{ block.shopify_attributes }}>
                        <span>{% render 'icon-instagram' %}</span>
                      </a>
                    {%- endif -%}
                  </div>
                </div>
                {% endif %}
              </div>
            {%- endfor -%}
          </div>

          {% unless section.settings.pagination_style == 'none' %}
            {% if section.settings.pagination_style == 'arrows' %}
              <div class="slide_arrow swiper-button-prev {{ settings.carousel_position }} {% if section.settings.disable_arrow == true %}hide_carrow{% endif %}">
              <div class="button {{ settings.carousel_style }}">
                <span>{% render 'icon-caret' %}</span>
              </div>
            </div>
            <div class="slide_arrow swiper-button-next {{ settings.carousel_position }} {% if section.settings.disable_arrow == true %}hide_carrow{% endif %}">
              <div class="button {{ settings.carousel_style }}">
                <span>{% render 'icon-caret' %}</span>
              </div>
            </div>
            {% endif %}
            <div class="swiper-pagination pagi_{{ section.settings.pagination_style }}"></div>
          {% endunless %}

        </div>
      </slider-carousel>
    </div>

  </div>
</div>


{% schema %}
{
  "name": "t:sections.social-media.name",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_width",
          "label": "t:sections.slideshow.settings.layout.options__1.label"
        },
        {
          "value": "grid",
          "label": "t:sections.slideshow.settings.layout.options__2.label"
        }
      ],
      "default": "grid",
      "label": "t:sections.slideshow.settings.layout.label"
    },
    {
      "type": "header",
      "content": "t:settings_schema.heading.head"
    },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "t:settings_schema.heading.settings.head_text.label_1"
    },
    {
      "type": "color",
      "id": "headcolor",
      "label": "t:settings_schema.heading.settings.head_text.txt_color",
      "default": "#DF6334",
      "info": "t:settings_schema.heading.settings.head_text.txt_info"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options__1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options__2.label"
        },
        {
          "value": "h0",
          "label": "t:sections.all.heading_size.options__3.label"
        }
      ],
      "default": "h0",
      "label": "t:settings_schema.heading.settings.head_text.label_2"
    },
    {
      "type": "select",
      "id": "heading_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.heading_position.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.heading_position.options__2.label"
        }
      ],
      "default": "left",
      "label": "t:settings_schema.heading.settings.head_text.label_3"
    },

    {
      "type": "select",
      "id": "display_type",
      "label": "t:sections.featured-collection.settings.display_type.label",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.featured-collection.settings.display_type.options__1.label"
        },
        {
          "value": "carousel",
          "label": "t:sections.featured-collection.settings.display_type.options__2.label"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3,
      "label": "t:sections.featured-collection.settings.columns_desktop.label"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.featured-collection.settings.image_ratio.options__1.label"
        },
        {
          "value": "portrait",
          "label": "t:sections.featured-collection.settings.image_ratio.options__2.label"
        },
        {
          "value": "square",
          "label": "t:sections.featured-collection.settings.image_ratio.options__3.label"
        }
      ],
      "default": "portrait",
      "label": "t:sections.featured-collection.settings.image_ratio.label"
    },
    {
      "type": "select",
      "id": "sociald_style",
      "label": "Layout style",
      "options": [
        {
          "value": "sociald_style1",
          "label": "Post images"
        },
        {
          "value": "sociald_style2",
          "label": "Tag stories with posts"
        },
        {
          "value": "sociald_style3",
          "label": "Post images with social account"
        }
      ],
      "default": "sociald_style3"
    },

    {
      "type": "header",
      "content": "Social account"
    },
    {
      "type": "color_scheme",
      "id": "social_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "social_bg_opacity",
      "min": 15,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Background opacity on hover",
      "default": 50 
    },
    {
      "type": "image_picker",
      "id": "insta_img",
      "label": "Avatar"
    },
    {
      "type": "select",
      "id": "user_image_shape",
      "options": [
        {
          "value": "orginal",
          "label": "Original"
        },
        {
          "value": "curve",
          "label": "Curve"
        },
        {
          "value": "circle",
          "label": "Circle"
        }
      ],
      "default": "circle",
      "label": "Shape"
    },
    {
      "type": "text",
      "id": "user_name",
      "default": "Account name",
      "label": "Name"
    },
    {
      "type": "text",
      "id": "button_label",
      "default": "Button label",
      "label": "t:sections.slideshow.blocks.slide.settings.button_label.label",
      "info": "t:sections.slideshow.blocks.slide.settings.button_label.info"
    },


    

    {
      "type": "header",
      "content": "t:sections.custom_text.settings.v_all.content"
    },
    {
      "type": "inline_richtext",
      "id": "view_label",
      "default": "View all",
      "label": "t:sections.custom_text.settings.text.label"
    },
    {
      "type": "color",
      "id": "headcolor1",
      "label": "t:settings_schema.heading.settings.head_text.txt_color",
      "default": "#DF6334",
      "info": "t:settings_schema.heading.settings.head_text.txt_info"
    },

    {
      "type": "header",
      "content": "t:sections.slideshow.settings.slider_visual.header"
    },
    {
      "type": "select",
      "id": "pagination_style",
      "options": [
        {
          "value": "none",
          "label": "t:sections.slideshow.settings.slider_visual.options__6.label"
        },
        {
          "value": "dots",
          "label": "t:sections.slideshow.settings.slider_visual.options__2.label"
        },
        {
          "value": "arrows",
          "label": "t:sections.slideshow.settings.slider_visual.options__4.label"
        }
      ],
      "default": "arrows",
      "label": "t:sections.slideshow.settings.slider_visual.label"
    },
    {
      "type": "checkbox",
      "id": "disable_arrow",
      "label": "t:sections.slideshow.settings.disable_arrow.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.slideshow.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "change_slides_speed",
      "min": 3,
      "max": 9,
      "step": 1,
      "unit": "s",
      "label": "t:sections.slideshow.settings.change_slides_speed.label",
      "default": 4
    },

    
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "social_image",
      "name": "t:sections.multicolumn.blocks.column.settings.image.label",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Post image"
        },
        {
          "type": "url",
          "id": "social_link",
          "label": "t:sections.custom_text.settings.link.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.social-media.name",
      "blocks": [
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        },
        {
          "type": "social_image"
        }
      ]
    }
  ]
}
{% endschema %}