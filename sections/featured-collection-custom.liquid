{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-rating.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-volume-pricing.css' | asset_url | stylesheet_tag: preload: true }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'quick-order-list.css' | asset_url | stylesheet_tag }}
{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'featured-collection-tabs.css' | asset_url | stylesheet_tag }}
{% unless card_product.has_only_default_variant %}
  {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
  {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
{% endunless %}

{%- if settings.quick_view_button == true -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- unless settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endunless -%}

{%- if settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if settings.show_variants == true -%}
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- style -%}
  .section-{{ section.id }}-padding .sectioncountdown .time .count {
    color: {{ section.settings.timercolor }};
  }
  {% if settings.swatch_position == true %}
    {% if settings.show_cardvendor %}
      .section-{{ section.id }}
      -padding .product-card-wrapper color-swatch {
        grid-row-start: 3;
      }
    {% else %}
    .section-{{ section.id }}
    -padding .product-card-wrapper color-swatch {
      grid-row-start: 2;
    }
  {% endif %}
{% endif %}
.section-{{ section.id }}
-padding .section-head strong
, .section-{{ section.id }}
-padding .section-head b {
  color: {{ section.settings.headcolor }};
}
.section-{{ section.id }}
-padding .card_number span {
  background: {{ section.settings.show_number_bg }};
  color: {{ section.settings.show_number_text }};
  border: 2px solid{{ section.settings.show_number_border }};
  border-radius: {{ section.settings.number_radius }}px;
}
.section-{{ section.id }}
-padding {
  padding-top: {{ section.settings.padding_top | times: 0.45 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.45 | round: 0 }}px;
}
@media screen and (min-width: 992px) {
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
}
{%- endstyle -%}


{%- liquid
  assign num_row = section.settings.show_row_on_desktop

  if section.blocks.size > 0
    if section.settings.collection.all_products_count > section.settings.products_to_show
      assign more_in_collection = true
    endif

  endif
-%}

<div class="color-{{ section.settings.color_scheme }} isolate gradient">
  <div
    class="unset-width collection {% if settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} section-{{ section.id }}-padding {% if section.settings.layout == 'full_width' %}section-full {% else %}page-width{% endif %}"
    id="collection-{{ section.id }}"
    data-id="{{ section.id }}">
    <div class="section-head-top {{ section.settings.heading_position }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      <div>
        {%- if section.settings.caption != blank -%}
          <p class="head_caption">{{ section.settings.caption }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
            <h2 class="section-head inline-richtext {{ section.settings.heading_size }} custom">
                {{ section.settings.title }}
              </h2>
        {%- endif -%}
        {%- if section.settings.description != blank or section.settings.show_description and section.settings.collection.description != empty -%}
          <div class="collection__description {{ section.settings.description_style }} rte">
            {%- if section.settings.show_description -%}
              {{ section.settings.collection.description }}
            {%- else -%}
              {{ section.settings.description -}}
            {%- endif %}
          </div>
        {%- endif -%}
      </div>
      {% if section.settings.show_section_count %}
        <div data-date="{{ section.settings.wb_enddate }}" class="sectioncountdown countd_all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <div class="time main_cdays">
            <span class="count wb_cdays">00</span>
            <span>{{ 'custom_data.data_inner.time_days' | t }}</span>
          </div>
          <div class="time main_chours">
            <span class="count wb_chours">00</span>
            <span>{{ 'custom_data.data_inner.time_hour' | t }}</span>
          </div>
          <div class="time main_cminutes">
            <span class="count wb_cminutes">00</span>
            <span>{{ 'custom_data.data_inner.time_min' | t }}</span>
          </div>
          <div class="time main_cseconds">
            <span class="count wb_cseconds">00</span>
            <span>{{ 'custom_data.data_inner.time_sec' | t }}</span>
          </div>
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        {% for collection_block in section.blocks %}
          {% if collection_block.settings.collection.all_products_count > section.settings.products_to_show %}
            {% assign more_in_collection = true %}
          {% else %}
            {% assign more_in_collection = false %}
          {% endif %}


          {%- if section.settings.show_view_all and more_in_collection and section.settings.view_label != blank -%}
            {%- if section.settings.view_button_pos == 'top' or section.settings.view_button_pos == 'both' -%}
              <div
                style="{% if forloop.first  %} display:block {% else %} display:none {% endif %}"
                collection-data="{% if collection_block.settings.collection_name != blank  %}{{ collection_block.settings.collection_name}}{% else %}{{- collection_block.settings.collection.title -}}{% endif %}"
                class="topc collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                <a
                  href="{{ collection_block.settings.collection.url }}"
                  class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
                  aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: collection_block.settings.collection.title | escape }}">
                  <span>{{ section.settings.view_label }}</span>
                </a>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      {% else %}
        {%- if section.settings.show_view_all and section.settings.view_label != blank -%}
          {%- if section.settings.view_button_pos == 'top' or section.settings.view_button_pos == 'both' -%}
            <div class="topc collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
              <a
                href="{{ section.settings.collection.url }}"
                class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
                aria-label="{{ 'sections.featured_collection.view_all_label' | t: collection_name: section.settings.collection.title | escape }}">
                <span>{{ section.settings.view_label }}</span>
              </a>
            </div>
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
    </div>
    {% if section.blocks.size > 0 %}
      <div class="collection-tabs--container">
        {% for col_block in section.blocks %}
          <button
            {% if forloop.first %}
            active
            {% endif %}
            collection-data="{% if col_block.settings.collection_name !=blank  %}{{ col_block.settings.collection_name}}{% else %}{{- col_block.settings.collection.title -}}{% endif %}"
            class="title-tab">
            {% if col_block.settings.collection_name != blank %}
              {{ col_block.settings.collection_name }}
            {% else %}
              {{ col_block.settings.collection.title }}
            {% endif %}
          </button>
        {% endfor %}
      </div>
      {% for col_block in section.blocks %}
        {%- liquid
          assign num_row = section.settings.show_row_on_desktop
          if col_block.settings.collection.all_products_count > section.settings.products_to_show
            assign more_in_collection = true
          endif
        -%}
        <product-grid class="product-grid-container" 
            id="{% if col_block.settings.collection_name !=blank  %}{{ col_block.settings.collection_name}}{% else %}{{- col_block.settings.collection.title -}}{% endif %}"
            {% if forloop.first %}
            style="display: block;"
            {% else %}
            style="display: none;"
            {% endif %}
        >
        {%- if col_block.settings.collection.products.size == 0 -%}
          <div
            id="{% if col_block.settings.collection_name !=blank  %}{{ col_block.settings.collection_name}}{% else %}{{- col_block.settings.collection.title -}}{% endif %}"
            class="collection collection--empty page-width"
            id="product-grid"
            data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {% comment %} {{
                                                                        'sections.collection_template.use_fewer_filters_html'
                                                                        | t: link: collection.url, class: 'underlined-link link'
                                                                }} {% endcomment %}
                <a
                  href="/"
                  class="button button--primary button-block"
                  style="max-width: 200px;">
                  <span>{{ 'sections.collection_template.collection_back_home' | t }}</span>
                </a>
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection">
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="listt-{{ settings.card_style }} grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop {% if settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} {% if section.settings.listing_mode == 'p_list' %} product-list{% endif %} {% if section.settings.listing_mode == 'p_gallery' %} product-gallery{% endif %}">
              {% liquid
                assign blockDIndex = 0
                assign blockMIndex = 0
                assign promotionBlock = section.blocks | map: 'settings' | sort: 'img_position'
                assign blockSize = section.blocks | size | minus: 1
              %}

              {%- for product in col_block.settings.collection.products -%}
                {% if forloop.index0 >= section.settings.products_per_page %}
                    {% break %}
                {% endif %}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}

                {%- if blockDIndex <= blockSize -%}
                  {%- for idx in (blockDIndex..blockSize) -%}
                    {% liquid
                      assign newDesktopPosition = promotionBlock[blockDIndex].img_position | minus: 1 | times: section.settings.columns_desktop | plus: 1
                    %}
                    {%- if forloop.parentloop.index == newDesktopPosition -%}
                      {% liquid
                        assign block = promotionBlock[idx]
                        assign blockDIndex = idx | plus: 1
                      %}
                      <li class="grid__item collection_media mediaimg-{{ idx }} banner banner--content-align-{{ block.desktop_content_alignment }}">
                        <div class="banner__media media">
                          {% if block.image != blank %}
                            {%- assign image_height = block.image.width
                                | divided_by: block.image.aspect_ratio
                                | round
                                                            -%}
                                                            {{ block.image
                                | image_url: width: 3840
                                | image_tag:
                                loading: 'lazy',
                                width: block.image.width,
                                height: image_height,
                                sizes: '100vw',
                                class: 'img-fluid',
                                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            }}
                          {% else %}
                            {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                            {%- if placeholder_slide == 1 -%}
                              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- else -%}
                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          {% endif %}
                        </div>

                        <div class="banner__content banner__content--{{ block.desktop_content_position }}">
                          {% if block.subheading != blank or block.heading != blank or block.button_label != blank %}
                            <div class="banner__box color-{{ block.content_color_scheme }} gradient {% if block.content_bg == false %}bg-transparent{% endif %}">
                              {% if block.subheading != blank %}
                                <div class="banner__subheading" {{ block.shopify_attributes }}>
                                  {{ block.subheading }}
                                </div>
                              {% endif %}
                              {% if block.heading != blank %}
                                <h3 class="banner__heading inline-richtext {{ block.heading_size }}" {{ block.shopify_attributes }}>
                                  {{ block.heading }}
                                </h3>
                              {% endif %}
                              {%- if block.button_label != blank -%}
                                <a
                                  {% if block.button_link == blank %}
                                  role="link"
                                  aria-disabled="true"
                                  {% else %}
                                  href="{{ block.button_link }}"
                                  {% endif %}
                                  class="{% if block.button_style == 'link' %}link underlined-link{% elsif block.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}">
                                  <span>{{- block.button_label | escape -}}</span>
                                </a>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>

                        {%- style -%}
                          .mediaimg-{{ idx }} .banner__box {
                            background-color: rgba(var(--color-background), {{ block.content_bg_opacity | divided_by: 100.0 }});
                          }
                        {%- endstyle -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                {%- if blockMIndex <= blockSize -%}
                  {%- for idx in (blockMIndex..blockSize) -%}
                    {% liquid
                      assign newMobilePosition = promotionBlock[blockMIndex].img_position | minus: 1 | times: section.settings.columns_mobile | plus: 1
                    %}
                    {%- if forloop.parentloop.index == newMobilePosition -%}
                      {% liquid
                        assign block = promotionBlock[idx]
                        assign blockMIndex = idx | plus: 1
                      %}
                      <li class="mobilemedia grid__item collection_media mediaimg-{{ idx }} banner banner--content-align-{{ block.desktop_content_alignment }}">
                        <div class="banner__media media">
                          {% if block.image != blank %}
                            {%- assign image_height = block.image.width
                                | divided_by: block.image.aspect_ratio
                                | round
                                                            -%}
                                                            {{ block.image
                                | image_url: width: 3840
                                | image_tag:
                                loading: 'lazy',
                                width: block.image.width,
                                height: image_height,
                                sizes: '100vw',
                                class: 'img-fluid',
                                widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            }}
                          {% else %}
                            {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                            {%- if placeholder_slide == 1 -%}
                              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- else -%}
                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          {% endif %}
                        </div>

                        <div class="banner__content banner__content--{{ block.desktop_content_position }}">
                          {% if block.subheading != blank or block.heading != blank or block.button_label != blank %}
                            <div class="banner__box color-{{ block.content_color_scheme }} gradient {% if block.content_bg == false %}bg-transparent{% endif %}">
                              {% if block.subheading != blank %}
                                <div class="banner__subheading" {{ block.shopify_attributes }}>
                                  {{ block.subheading }}
                                </div>
                              {% endif %}
                              {% if block.heading != blank %}
                                <h3 class="banner__heading inline-richtext {{ block.heading_size }}" {{ block.shopify_attributes }}>
                                  {{ block.heading }}
                                </h3>
                              {% endif %}
                              {%- if block.button_label != blank -%}
                                <a
                                  {% if block.button_link == blank %}
                                  role="link"
                                  aria-disabled="true"
                                  {% else %}
                                  href="{{ block.button_link }}"
                                  {% endif %}
                                  class="{% if block.button_style == 'link' %}link underlined-link{% elsif block.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}">
                                  <span>{{- block.button_label | escape -}}</span>
                                </a>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>

                        {%- style -%}
                          .mediaimg-{{ idx }} .banner__box {
                            background-color: rgba(var(--color-background), {{ block.content_bg_opacity | divided_by: 100.0 }});
                          }
                        {%- endstyle -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                <li class="grid__item">
                  {% render 'card-product'
                    ,
                        card_product: product
                                            ,
                        media_aspect_ratio: settings.image_ratio
                                            ,
                        show_secondary_image: settings.show_secondary_image
                                            ,
                        show_cardtype: settings.show_cardtype
                                            ,
                        show_vendor: settings.show_cardvendor
                                            ,
                        show_color_swatch: settings.show_color_swatch
                                            ,
                        quick_view_button: settings.quick_view_button
                                            ,
                        enable_desc: section.settings.enable_desc
                                            ,
                        card_style: settings.card_style
                                            ,
                        show_variants: settings.show_variants
                                            ,
                        show_number: section.settings.show_number
                                            ,
                        forloop_number: forloop.index
                                            ,
                        picker_type: settings.picker_type
                                            ,
                        show_colorswatch: settings.show_colorswatch
                                            ,
                        disable_fquickview: false
                                            ,
                        disable_faddcart: false
                                            ,
                        disable_fvariant: false
                                            ,
                        only_addcart: false
                                            ,
                        lazy_load: lazy_load
                                            ,
                        section_id: section.id
                                            ,
                        show_quantity: settings.show_quantity
                                            ,
                        quick_add: settings.quick_add
                  %}
                </li>
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination'
                , paginate: paginate
                , anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </product-grid>
      {% endfor %}
    {% else %}
      <div class="product-grid-container" id="ProductGridContainer">
        {%- if section.settings.collection.products.size == 0 -%}
          <div
            class="collection collection--empty page-width"
            id="product-grid"
            data-id="{{ section.id }}">
            <div class="loading-overlay gradient"></div>
            <div class="title-wrapper center">
              <h2 class="title title--primary">
                {{ 'sections.collection_template.empty' | t -}}
                <br>
                {% comment %} {{
                                                                        'sections.collection_template.use_fewer_filters_html'
                                                                        | t: link: collection.url, class: 'underlined-link link'
                                                                }} {% endcomment %}
                <a
                  href="/"
                  class="button button--primary button-block"
                  style="max-width: 200px;">
                  <span>{{ 'sections.collection_template.collection_back_home' | t }}</span>
                </a>
              </h2>
            </div>
          </div>
        {%- else -%}
          <div class="collection">
            <div class="loading-overlay gradient"></div>
            <ul
              id="product-grid"
              data-id="{{ section.id }}"
              class="listt-{{ settings.card_style }} grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop {% if settings.quick_add == 'bulk' %} collection-quick-add-bulk{% endif %} {% if section.settings.listing_mode == 'p_list' %} product-list{% endif %} {% if section.settings.listing_mode == 'p_gallery' %} product-gallery{% endif %}">
              {% liquid
                assign blockDIndex = 0
                assign blockMIndex = 0
                assign promotionBlock = section.blocks | map: 'settings' | sort: 'img_position'
                assign blockSize = section.blocks | size | minus: 1
              %}

              {%- for product in section.settings.collection.products -%}
                {% if forloop.index0 >= section.settings.products_per_page %}
                    {% break %}
                {% endif %}
                {% assign lazy_load = false %}
                {%- if forloop.index > 2 -%}
                  {%- assign lazy_load = true -%}
                {%- endif -%}

                {%- if blockDIndex <= blockSize -%}
                  {%- for idx in (blockDIndex..blockSize) -%}
                    {% liquid
                      assign newDesktopPosition = promotionBlock[blockDIndex].img_position | minus: 1 | times: section.settings.columns_desktop | plus: 1
                    %}
                    {%- if forloop.parentloop.index == newDesktopPosition -%}
                      {% liquid
                        assign block = promotionBlock[idx]
                        assign blockDIndex = idx | plus: 1
                      %}
                      <li class="grid__item collection_media mediaimg-{{ idx }} banner banner--content-align-{{ block.desktop_content_alignment }}">
                        <div class="banner__media media">
                          {% if block.image != blank %}
                            {%- assign image_height = block.image.width
        | divided_by: block.image.aspect_ratio
        | round
                                    -%}
                                    {{ block.image
        | image_url: width: 3840
        | image_tag:
        loading: 'lazy',
        width: block.image.width,
        height: image_height,
        sizes: '100vw',
        class: 'img-fluid',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            }}
                          {% else %}
                            {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                            {%- if placeholder_slide == 1 -%}
                              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- else -%}
                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          {% endif %}
                        </div>

                        <div class="banner__content banner__content--{{ block.desktop_content_position }}">
                          {% if block.subheading != blank or block.heading != blank or block.button_label != blank %}
                            <div class="banner__box color-{{ block.content_color_scheme }} gradient {% if block.content_bg == false %}bg-transparent{% endif %}">
                              {% if block.subheading != blank %}
                                <div class="banner__subheading" {{ block.shopify_attributes }}>
                                  {{ block.subheading }}
                                </div>
                              {% endif %}
                              {% if block.heading != blank %}
                                <h3 class="banner__heading inline-richtext {{ block.heading_size }}" {{ block.shopify_attributes }}>
                                  {{ block.heading }}
                                </h3>
                              {% endif %}
                              {%- if block.button_label != blank -%}
                                <a
                                  {% if block.button_link == blank %}
                                  role="link"
                                  aria-disabled="true"
                                  {% else %}
                                  href="{{ block.button_link }}"
                                  {% endif %}
                                  class="{% if block.button_style == 'link' %}link underlined-link{% elsif block.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}">
                                  <span>{{- block.button_label | escape -}}</span>
                                </a>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>

                        {%- style -%}
                          .mediaimg-{{ idx }} .banner__box {
                            background-color: rgba(var(--color-background), {{ block.content_bg_opacity | divided_by: 100.0 }});
                          }
                        {%- endstyle -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}

                {%- if blockMIndex <= blockSize -%}
                  {%- for idx in (blockMIndex..blockSize) -%}
                    {% liquid
                      assign newMobilePosition = promotionBlock[blockMIndex].img_position | minus: 1 | times: section.settings.columns_mobile | plus: 1
                    %}
                    {%- if forloop.parentloop.index == newMobilePosition -%}
                      {% liquid
                        assign block = promotionBlock[idx]
                        assign blockMIndex = idx | plus: 1
                      %}
                      <li class="mobilemedia grid__item collection_media mediaimg-{{ idx }} banner banner--content-align-{{ block.desktop_content_alignment }}">
                        <div class="banner__media media">
                          {% if block.image != blank %}
                            {%- assign image_height = block.image.width
        | divided_by: block.image.aspect_ratio
        | round
                                    -%}
                                    {{ block.image
        | image_url: width: 3840
        | image_tag:
        loading: 'lazy',
        width: block.image.width,
        height: image_height,
        sizes: '100vw',
        class: 'img-fluid',
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            }}
                          {% else %}
                            {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
                            {%- if placeholder_slide == 1 -%}
                              {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- else -%}
                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            {%- endif -%}
                          {% endif %}
                        </div>

                        <div class="banner__content banner__content--{{ block.desktop_content_position }}">
                          {% if block.subheading != blank or block.heading != blank or block.button_label != blank %}
                            <div class="banner__box color-{{ block.content_color_scheme }} gradient {% if block.content_bg == false %}bg-transparent{% endif %}">
                              {% if block.subheading != blank %}
                                <div class="banner__subheading" {{ block.shopify_attributes }}>
                                  {{ block.subheading }}
                                </div>
                              {% endif %}
                              {% if block.heading != blank %}
                                <h3 class="banner__heading inline-richtext {{ block.heading_size }}" {{ block.shopify_attributes }}>
                                  {{ block.heading }}
                                </h3>
                              {% endif %}
                              {%- if block.button_label != blank -%}
                                <a
                                  {% if block.button_link == blank %}
                                  role="link"
                                  aria-disabled="true"
                                  {% else %}
                                  href="{{ block.button_link }}"
                                  {% endif %}
                                  class="{% if block.button_style == 'link' %}link underlined-link{% elsif block.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}">
                                  <span>{{- block.button_label | escape -}}</span>
                                </a>
                              {%- endif -%}
                            </div>
                          {% endif %}
                        </div>

                        {%- style -%}
                          .mediaimg-{{ idx }} .banner__box {
                            background-color: rgba(var(--color-background), {{ block.content_bg_opacity | divided_by: 100.0 }});
                          }
                        {%- endstyle -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
                <li class="grid__item">
                  {% render 'card-product'
                    ,
                    card_product: product
                                        ,
                    media_aspect_ratio: settings.image_ratio
                                        ,
                    show_secondary_image: settings.show_secondary_image
                                        ,
                    show_cardtype: settings.show_cardtype
                                        ,
                    show_vendor: settings.show_cardvendor
                                        ,
                    show_color_swatch: settings.show_color_swatch
                                        ,
                    quick_view_button: settings.quick_view_button
                                        ,
                    enable_desc: section.settings.enable_desc
                                        ,
                    card_style: settings.card_style
                                        ,
                    show_variants: settings.show_variants
                                        ,
                    show_number: section.settings.show_number
                                        ,
                    forloop_number: forloop.index
                                        ,
                    picker_type: settings.picker_type
                                        ,
                    show_colorswatch: settings.show_colorswatch
                                        ,
                    disable_fquickview: false
                                        ,
                    disable_faddcart: false
                                        ,
                    disable_fvariant: false
                                        ,
                    only_addcart: false
                                        ,
                    lazy_load: lazy_load
                                        ,
                    section_id: section.id
                                        ,
                    show_quantity: settings.show_quantity
                                        ,
                    quick_add: settings.quick_add
                  %}
                </li>
              {%- endfor -%}
            </ul>

            {%- if paginate.pages > 1 -%}
              {% render 'pagination'
                , paginate: paginate
                , anchor: '' %}
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {% endif %}
  </div>
</div>

<script>
   
    document.addEventListener('DOMContentLoaded', () => {
        const buttons = document.querySelectorAll('.title-tab');
        const collectionDivs = document.querySelectorAll('product-grid[id]');
        const seeAllBtns = document.querySelectorAll('.collection__view-all');
        
        
        buttons.forEach(button => {
            button.addEventListener('click', () => {
                buttons.forEach(btn => btn.removeAttribute('active'));
                button.setAttribute('active', '');
            
                const targetId = button.getAttribute('collection-data');
            
                collectionDivs.forEach(div => {
                div.style.display = 'none';
                });
            
                seeAllBtns.forEach(btn => {
                btn.style.display = 'none';
                });
            
                const targetDiv = document.getElementById(targetId);
                targetDiv.style.display = 'block';
                const targetBtns = document.querySelectorAll(`div[collection-data="${targetId}"]`);
                targetBtns.forEach(btn => {
                btn.style.display = 'block';
                });
            });
        });
    })
  // TIMER
  setInterval(countDown, 1000);
  function countDown() {
    const countCardSections = document.querySelectorAll('.countd_all');
    countCardSections.forEach((countdownSection) => {
      var countDownDate = new Date(countdownSection.getAttribute('data-date')).getTime();
      var now = new Date().getTime();
      var distance = countDownDate - now;
      if (distance < 0 || isNaN(countDownDate)) {
        countdownSection.querySelector('.main_cdays .wb_cdays').textContent = "00";
        countdownSection.querySelector('.main_chours .wb_chours').textContent = "00";
        countdownSection.querySelector('.main_cminutes .wb_cminutes').textContent = "00";
        countdownSection.querySelector('.main_cseconds .wb_cseconds').textContent = "00";
      }
      else {
        countdownSection.querySelector('.main_cdays .wb_cdays').textContent = Math.floor(distance / (1000 * 60 * 60 * 24));
        countdownSection.querySelector('.main_chours .wb_chours').textContent = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        countdownSection.querySelector('.main_cminutes .wb_cminutes').textContent = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        countdownSection.querySelector('.main_cseconds .wb_cseconds').textContent = Math.floor((distance % (1000 * 60)) / 1000);
      }
    });
  }
</script>

