{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
{{ 'section-main-policy.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 992px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}


<div class="main-page {% if section.settings.layout == 'full_width' %}section-full {% else %}page-width{% endif %}  section-{{ section.id }}-padding">
  <h1 class="title-policy {{ section.settings.heading_position }} main-page-title page-title {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ section.settings.policy_heading }}
  </h1>
  {% comment %} <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
                                                                                                                                                                                                                                                                                                                                                                                                                                                      {{ page.content }}
                                                                                                                                                                                                          </div> {% endcomment %}

  <div class="policy-tabs--container">
    {% for block in section.blocks %}
      <button
        policy-title="{{block.settings.page_picker.title}}"
        page-url="{{block.settings.page_picker.url}}"
        class="policy-tab--title"
        {% if page.handle == block.settings.page_picker.handle %}
        active
        {% endif %}>{% if block.settings.page_tab !=blank %}
          {{ block.settings.page_tab}} {% else %}
          {{ block.settings.page_picker.title }}
        {% endif %} </button>
    {% endfor %}
  </div>
  {% for block in section.blocks %}
    {% if page.handle == block.settings.page_picker.handle %}
      <div class="policy-content" id="{{block.settings.page_picker.title}}">
        {{ block.settings.page_picker.content }}
      </div>
    {% endif %}
  {% endfor %}
</div>
<script src="{{ 'page-policy-tabs.js' | asset_url }}" defer="defer"></script>
{% schema %}
  {
    "name": "Policy page",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "label": "t:sections.featured-blog.settings.heading.label",
        "id": "policy_heading"
      },
      {
        "type": "select",
        "id": "heading_position",
        "options": [
          {
            "value": "left",
            "label": "t:sections.all.heading_position.options__1.label"
          }, {
            "value": "center",
            "label": "t:sections.all.heading_position.options__2.label"
          }
        ],
        "default": "center",
        "label": "Heading alignment"
      },
      {
        "type": "select",
        "id": "layout",
        "options": [
          {
            "value": "full_width",
            "label": "t:sections.slideshow.settings.layout.options__1.label"
          }, {
            "value": "grid",
            "label": "t:sections.slideshow.settings.layout.options__2.label"
          }
        ],
        "default": "grid",
        "label": "t:sections.slideshow.settings.layout.label"
      },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "blocks": [
      {
        "type": "policy-tabs",
        "name": "Policy tabs",
        "settings": [
          {
            "type": "page",
            "id": "page_picker",
            "label": "Policy page"
          },
          {
            "type": "text",
            "id": "page_tab",
            "label": "Policy page tab name"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Policy page",
        "blocks": [
          {
            "type": "policy-tabs"
          }
        ]
      }
    ]

  }
{% endschema %}