{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign aspect_image = section.settings.def_image | default: collection.image
  assign show_image = false
  if section.settings.def_image != blank or section.settings.image_mobile != blank or section.settings.show_collection_image and collection.image
    assign show_image = true
  endif

  assign hero_layout_class = 'overlay'
  if show_image == false
    assign hero_layout_class = 'column'
  endif

  assign alignment_mobile_vertical = section.settings.alignment_mobile_vertical
  assign alignment_mobile_horizontal = section.settings.alignment_mobile_horizontal
  assign alignment_desktop_vertical = section.settings.alignment_desktop_vertical
  assign alignment_desktop_horizontal = section.settings.alignment_desktop_horizontal

  capture classes_gradient
    render 'styles-gradient', desktop_horizontal_position: alignment_desktop_horizontal, mobile_vertical_position: alignment_mobile_vertical, desktop_vertical_position: alignment_desktop_vertical
  endcapture
  assign classes_gradient = classes_gradient | strip | strip_newlines

  capture classes_aspect_ratio
    render 'styles-aspect-ratio', mobile_aspect_ratio: section.settings.aspect_ratio_mobile, desktop_aspect_ratio: section.settings.aspect_ratio_desktop
  endcapture
  assign classes_aspect_ratio = classes_aspect_ratio | strip | strip_newlines

  capture class_spacing
    render 'styles-spacing', settings: section.settings
  endcapture
  assign class_spacing = class_spacing | strip | strip_newlines

  capture class_content_alignment
    render 'styles-content-alignment', settings: section.settings
  endcapture
  assign class_content_alignment = class_content_alignment | strip | strip_newlines
-%}
{%- style -%}
  .collection-hero-{{ section.id }}-wrapper {
    max-width: 100%;
    width: 100%;
  }

  @media(max-width: 750px) {
    .collection-hero-{{ section.id }}-wrapper {
      margin: 0 8px;
      width: calc(100% - 16px);
    }
    .collection-hero__text-wrapper {
      padding: 8px !important;
    }
  }

  .collection-hero-{{ section.id }} .collection-hero__title,
  .collection-hero-{{ section.id }} .breadcrumb,
  .collection-hero-{{ section.id }} .breadcrumb a,
  .collection-hero-{{ section.id }} .breadcrumb span,
  .collection-hero-{{ section.id }} .collection-hero__description {
    {% if show_image %}
      color: {{ section.settings.color_image }} !important;
    {% else %}
      color: {{ section.settings.color_no_image }} !important;
    {% endif %}
  }

  {% if show_image == false %}
    .collection-hero-{{ section.id }} .breadcrumb {
      opacity: 1;
    }
  {% endif %}

  .collection-hero-{{ section.id }} {
    min-height: auto;
  }
  {% if section.settings.image_height == 'custom' %}
  /* Mobile custom height */
  .collection-hero-{{ section.id }} .collection-hero__image-wrapper {
    height: {{ section.settings.mobile_custom_height }}px;
  }
  /* Desktop custom height */
  @media screen and (min-width: 992px) {
    .collection-hero-{{ section.id }} .collection-hero__image-wrapper {
      height: {{ section.settings.desktop_custom_height }}px;
    }
  }
  {% endif %}



  .collection-hero-{{ section.id }} .collection_row .row_coll_inner {
    background-color: {{ section.settings.coll_bgcolor }};
    border-radius: 12px;
    padding: 40px;
    overflow: hidden;
    {%- if section.settings.image_height == 'small' -%}
      min-height: 189px !important;
    {%- elsif section.settings.image_height == 'medium' -%}
      min-height: 300px !important;
    {%- elsif section.settings.image_height == 'large' -%}
      min-height: 400px !important;
    {%- elsif section.settings.image_height == 'custom' -%}
      min-height: {{ section.settings.desktop_custom_height }}px !important;
    {%- endif -%}
  }
  .collection-hero-{{ section.id }} .collection-hero__title {
    text-transform: uppercase;
    font-weight: 800;
    margin: 0;
    font-size: 4.4rem;
    line-height: 1.2;
    color: {{ section.settings.color_image }};
    text-align: inherit !important;
  }
  .collection-hero-{{ section.id }} .breadcrumb {
    font-size: 1.4rem;
    color: {{ section.settings.color_image }};
    opacity: 0.7;
    margin-top: 8px;
    text-transform: none;
    font-weight: 400;
    text-align: inherit !important;
  }
  .collection-hero-{{ section.id }} .breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  /* Overlay Layout Styles */
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__inner {
    position: relative;
    overflow: hidden;
    {%- if section.settings.image_height == 'small' -%}
      min-height: 189px !important;
    {%- elsif section.settings.image_height == 'medium' -%}
      min-height: 300px !important;
    {%- elsif section.settings.image_height == 'large' -%}
      min-height: 400px !important;
    {%- elsif section.settings.image_height == 'custom' -%}
      min-height: {{ section.settings.desktop_custom_height }}px !important;
    {%- endif -%}
  }
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__text-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
    padding: 40px;
    background: transparent !important;
  }
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__image-wrapper {
    position: absolute !important;
    top: 0;
    left: 0;
    width: 100% !important;
    height: 100% !important;
    z-index: 1;
    margin: 0 !important;
  }
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__inner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ section.settings.coll_bgcolor }};
    opacity: {{ section.settings.coll_overlay | divided_by: 100.0 }};
    z-index: 2;
  }
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__image-container {
    height: 100%;
    width: 100%;
  }
  .collection-hero-{{ section.id }}.collection_overlay .collection-hero__image-container img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-height: none;
  }

  .collection-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
    list-style: none;
    padding: 0;
  }
  .collection-hero-tag a {
    display: block;
    padding: 10px 20px;
    border: 1px solid #e5e5e5;
    border-radius: 4px;
    text-decoration: none;
    color: #333;
    font-size: 1.4rem;
    font-weight: 500;
    background: #fff;
    transition: all 0.2s ease;
  }
  .collection-hero-tag a:hover {
    border-color: #000;
    background: #f9f9f9;
  }
  @media screen and (max-width: 991px) {
    .collection-hero-{{ section.id }} .collection_row .row_coll_inner {
      padding: 20px;
      flex-direction: column;
      align-items: flex-start;
    }
    .collection-hero-{{ section.id }} .collection_row .collection-hero__image-wrapper {
      width: 100% !important;
      margin-top: 20px;
      justify-content: center;
    }
    .collection-hero-{{ section.id }} .collection-hero__title {
      font-size: 1.8rem;
    }
  }
  @media screen and (max-width: 749px) {
    .collection-hero-tags {
      overflow-x: auto;
      flex-wrap: nowrap;
      margin-left: -15px;
      margin-right: -15px;
      padding-left: 15px;
      padding-right: 15px;
      padding-bottom: 8px;
    }
    .collection-hero-tag a {
    }
  }
  @media(min-width: 768px) {
    .collection-hero-{{ section.id }}-wrapper {
      max-width: unset !important;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
  }

    @media(min-width: 1024px) {
    .collection-hero-{{ section.id }}-wrapper {
      padding: 0 6rem;
    }
  }
  .collection-hero__no-image {
    padding-top: 40px;
    padding-bottom: 40px;
    background-color: #f4f4f4; /* Subtle background for visibility */
    border-radius: 8px;
    min-height: auto !important;
  }
  .collection-hero__no-image .collection-hero__title {
    color: {{ section.settings.color_no_image }} !important;
  }
  .collection-hero__no-image .breadcrumb {
    color: {{ section.settings.color_no_image }} !important;
  }
  @media screen and (max-width: 991px) {
    .collection-hero__no-image {
      padding: 20px;
    }
  }
{%- endstyle -%}

<div class="collection-hero-{{ section.id }}-wrapper">
  <div class="collection-hero-{{ section.id }} {{ hero_layout_class | prepend: 'collection_' }} {{ class_spacing }}">
    <div class="collection-hero {{ hero_layout_class | prepend: 'collection_' }} {% if section.settings.layout == 'full_width' %}section-full-nospace{% else %}page-width{% endif %}">
      {%- liquid
        assign banner_aspect_style = ''
        if section.settings.image_height == 'adapt' and aspect_image != blank
          assign banner_aspect_style = 'aspect-ratio: ' | append: aspect_image.aspect_ratio | append: ' !important;'
        endif
      -%}
      <div class="collection-hero__inner {% if hero_layout_class == 'overlay' and show_image %}{{ class_content_alignment }}{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %} {% if show_image == false %} collection-hero__no-image{% endif %}"
        {% if hero_layout_class == 'overlay' and banner_aspect_style != '' %}
          style="{{ banner_aspect_style }}"
        {% endif %}
      >
        {% if hero_layout_class == 'column' or show_image == false %}
          <div class="row_coll_inner {{ class_content_alignment }}{% if section.settings.layout == 'full_width' %} page-width{% endif %}">
        {% endif %}

        <div class="collection-hero__text-wrapper {{ class_content_alignment }} {% if show_image %} coll_content_width{% endif %} {% if hero_layout_class == 'overlay' and section.settings.coll_overlay > 0 and show_image %}{{ classes_gradient }}{% endif %}">
          <h1 class="collection-hero__title">
            <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
            {{- collection.title | escape -}}
          </h1>

          <nav class="breadcrumb" role="navigation" aria-label="breadcrumbs">
            <a href="{{ routes.root_url }}" class="full-unstyled-link" title="{{ 'custom_data.data_inner.home' | t }}">
              {{- 'custom_data.data_inner.home' | t -}}
            </a>
            {% if template contains 'collection' and collection.handle %}
              <span aria-hidden="true">{% render 'icon-breadcrumb' %}</span>
              {% if current_tags %}
                {% capture url %}/collections/{{ collection.handle }}{% endcapture %}
                {{ collection.title | link_to: url }}
                <span aria-hidden="true">{% render 'icon-breadcrumb' %}</span>
                <span>{{ current_tags | join: ' + ' }}</span>
              {% else %}
                <span>{{ collection.title }}</span>
              {% endif %}
            {% endif %}
          </nav>

          {%- if section.settings.show_collection_description == true and collection.description.size > 0 -%}
            <div class="collection-hero__description rte">{{ collection.description }}</div>
          {%- endif -%}
        </div>

        {% if show_image %}
          {%- liquid
            assign image_classes = classes_aspect_ratio
            if section.settings.image_height == 'adapt'
              assign image_classes = ''
            endif
          -%}
          <div class="collection-hero__image-wrapper banner--{{ section.settings.image_height }} {{ image_classes }}"
            {% if hero_layout_class == 'column' and section.settings.image_height == 'adapt' and banner_aspect_style != '' %}
              style="{{ banner_aspect_style }}"
            {% endif %}
          >
            {%- if section.settings.def_image != blank -%}
              <div class="collection-hero__image-container">
                {%- liquid
                  assign desktop_image_class = 'collection-hero__image'
                  if section.settings.image_mobile != blank
                    assign desktop_image_class = desktop_image_class | append: ' small-hide medium-hide'
                  endif
                -%}
                {{
                  section.settings.def_image
                  | image_url: width: 1500
                  | image_tag:
                    loading: 'eager',
                    sizes: '(min-width: 992px) 50vw, 100vw',
                    widths: '375, 550, 750, 1100, 1500',
                    alt: collection.title,
                    class: desktop_image_class
                }}
                {%- if section.settings.image_mobile != blank -%}
                  {{
                    section.settings.image_mobile
                    | image_url: width: 750
                    | image_tag:
                      loading: 'eager',
                      sizes: '100vw',
                      widths: '375, 550, 750',
                      alt: collection.title,
                      class: 'collection-hero__image large-up-hide'
                  }}
                {%- endif -%}
              </div>
            {%- elsif section.settings.show_collection_image and collection.image -%}
              <div class="collection-hero__image-container">
                {%- liquid
                  assign desktop_image_class = 'collection-hero__image'
                  if section.settings.image_mobile != blank
                    assign desktop_image_class = desktop_image_class | append: ' small-hide medium-hide'
                  endif
                -%}
                {{
                  collection.image
                  | image_url: width: 1500
                  | image_tag:
                    loading: 'eager',
                    sizes: '(min-width: 992px) 50vw, 100vw',
                    widths: '375, 550, 750, 1100, 1500',
                    alt: collection.title,
                    class: desktop_image_class
                }}
                {%- if section.settings.image_mobile != blank -%}
                  {{
                    section.settings.image_mobile
                    | image_url: width: 750
                    | image_tag:
                      loading: 'eager',
                      sizes: '100vw',
                      widths: '375, 550, 750',
                      alt: collection.title,
                      class: 'collection-hero__image large-up-hide'
                  }}
                {%- endif -%}
              </div>
            {%- elsif section.settings.image_mobile != blank -%}
              <div class="collection-hero__image-container">
                {{
                  section.settings.image_mobile
                  | image_url: width: 750
                  | image_tag:
                    loading: 'eager',
                    sizes: '100vw',
                    widths: '375, 550, 750',
                    alt: collection.title,
                    class: 'collection-hero__image'
                }}
              </div>
            {%- endif -%}
          </div>
        {% endif %}

        {% if hero_layout_class == 'column' or show_image == false %}
          </div>
        {% endif %}
      </div>
      </div>
    </div>

    {% comment %} Collection Tags Section {% endcomment %}
    {%- assign has_tags = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'tag' and block.settings.text != blank -%}
        {%- assign has_tags = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_tags -%}
      <div class="collection-hero-tags-wrapper page-width">
        <ul class="collection-hero-tags list-unstyled">
          {%- for block in section.blocks -%}
            {%- if block.type == 'tag' and block.settings.text != blank -%}
              <li class="collection-hero-tag" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="full-unstyled-link">
                    {{- block.settings.text | escape -}}
                  </a>
                {%- else -%}
                  <span>{{ block.settings.text | escape }}</span>
                {%- endif -%}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    {%- endif -%}
  </div>
</div>
{% schema %}
{
  "name": "t:sections.main-collection-banner.name",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "full_width",
          "label": "t:sections.slideshow.settings.layout.options__1.label"
        },
        {
          "value": "grid",
          "label": "t:sections.slideshow.settings.layout.options__2.label"
        }
      ],
      "default": "full_width",
      "label": "t:sections.slideshow.settings.layout.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.main-collection-banner.settings.paragraph.content"
    },
    {
      "type": "image_picker",
      "id": "def_image",
      "label": "Default collection image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile collection image"
    },
    {
      "type": "checkbox",
      "id": "show_collection_image",
      "default": false,
      "label": "t:sections.main-collection-banner.settings.show_collection_image.label",
      "info": "t:sections.main-collection-banner.settings.show_collection_image.info"
    },
    {
      "type": "checkbox",
      "id": "show_collection_description",
      "default": true,
      "label": "t:sections.main-collection-banner.settings.show_collection_description.label"
    },
    {
      "type": "select",
      "id": "image_height",
      "options": [
        {
          "value": "adapt",
          "label": "t:sections.image-with-text.settings.height.options__1.label"
        },
        {
          "value": "small",
          "label": "t:sections.image-banner.settings.image_height.options__2.label"
        },
        {
          "value": "medium",
          "label": "t:sections.image-banner.settings.image_height.options__3.label"
        },
        {
          "value": "large",
          "label": "t:sections.image-banner.settings.image_height.options__4.label"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "medium",
      "label": "Image height",
      "info": "t:sections.main-collection-banner.settings.image_height.info"
    },
    {
      "type": "header",
      "content": "Custom Height Settings",
      "info": "These settings apply only when 'Custom' is selected for Image height"
    },
    {
      "type": "range",
      "id": "desktop_custom_height",
      "min": 200,
      "max": 700,
      "step": 10,
      "unit": "px",
      "label": "Desktop custom height",
      "default": 400,
      "info": "Set a custom height for desktop devices (992px and above)"
    },
    {
      "type": "range",
      "id": "mobile_custom_height",
      "min": 150,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Mobile custom height",
      "default": 300,
      "info": "Set a custom height for mobile devices (below 992px)"
    },
    {
      "type": "color",
      "id": "coll_bgcolor",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_image",
      "label": "Color with image",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_no_image",
      "label": "Color no image",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "coll_overlay",
      "min": 1,
      "max": 100,
      "step": 1,
      "default": 50,
      "unit": "%",
      "label": "Background overlay"
    },
    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "select",
      "id": "margin_top",
      "label": "Margin top mobile",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "margin_bottom",
      "label": "Margin bottom mobile",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "margin_top_desktop",
      "label": "Margin top desktop",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "margin_bottom_desktop",
      "label": "Margin bottom desktop",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "none"
    },
    {
      "type": "header",
      "content": "Aspect Ratio"
    },
    {
      "type": "select",
      "id": "aspect_ratio_desktop",
      "label": "Desktop aspect ratio",
      "options": [
        { "value": "original_ratio", "label": "Original" },
        { "value": "4:1", "label": "4:1" },
        { "value": "3:1", "label": "3:1" },
        { "value": "2:1", "label": "2:1" },
        { "value": "16:9", "label": "16:9" },
        { "value": "3:2", "label": "3:2" },
        { "value": "4:3", "label": "4:3" },
        { "value": "1:1", "label": "1:1" }
      ],
      "default": "2:1"
    },
    {
      "type": "select",
      "id": "aspect_ratio_mobile",
      "label": "Mobile aspect ratio",
      "options": [
        { "value": "3:1", "label": "3:1" },
        { "value": "2:1", "label": "2:1" },
        { "value": "4:3", "label": "4:3" },
        { "value": "1:1", "label": "1:1" },
        { "value": "3:4", "label": "3:4" },
        { "value": "2:3", "label": "2:3" }
      ],
      "default": "2:3"
    },
    {
      "type": "header",
      "content": "t:settings.mobile_content_alignment"
    },
    {
      "type": "select",
      "id": "alignment_mobile_vertical",
      "label": "t:settings.vertical_alignment",
      "options": [
        {
          "label": "t:options.alignment.vertical.start",
          "value": "top"
        },
        {
          "label": "t:options.alignment.vertical.center",
          "value": "center"
        },
        {
          "label": "t:options.alignment.vertical.end",
          "value": "bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "alignment_mobile_horizontal",
      "label": "t:settings.horizontal_alignment",
      "options": [
        {
          "label": "t:options.alignment.horizontal.start",
          "value": "left"
        },
        {
          "label": "t:options.alignment.horizontal.center",
          "value": "center"
        },
        {
          "label": "t:options.alignment.horizontal.end",
          "value": "right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "t:content.header.desktop_content_alignment"
    },
    {
      "type": "select",
      "id": "alignment_desktop_vertical",
      "label": "t:settings.vertical_alignment",
      "options": [
        {
          "label": "t:options.alignment.vertical.start",
          "value": "top"
        },
        {
          "label": "t:options.alignment.vertical.center",
          "value": "center"
        },
        {
          "label": "t:options.alignment.vertical.end",
          "value": "bottom"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "alignment_desktop_horizontal",
      "label": "t:settings.horizontal_alignment",
      "options": [
        {
          "label": "t:options.alignment.horizontal.start",
          "value": "left"
        },
        {
          "label": "t:options.alignment.horizontal.center",
          "value": "center"
        },
        {
          "label": "t:options.alignment.horizontal.end",
          "value": "right"
        }
      ],
      "default": "center"
    }
  ],
  "blocks": [
    {
