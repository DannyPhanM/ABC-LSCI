{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  {% if section.settings.zoom_img == true %}
  .only_glry_section.section-{{ section.id }}-padding .banner .banner__media img {
  transform: scale(1);
  transition: var(--duration-long) ease;
  }
  .only_glry_section.section-{{ section.id }}-padding .banner:hover .banner__media img {
  transform: scale(1.05);
  }
  {%- endif %}
  .section-{{ section.id }}-padding .section-head strong, .section-{{ section.id }}-padding .section-head b {
  color: {{ section.settings.headcolor }};
  }
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top | times: 0.45 | round: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | times: 0.45 | round: 0 }}px;
  }
  @media screen and (min-width: 992px) {
  .section-{{ section.id }}-padding {
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  }
{%- endstyle -%}

<div
  class="section-{{ section.id }}-padding color-{{ section.settings.section_color_scheme }} gradient gallery_img only_glry_section"
>
  <div class="{% if section.settings.layout == 'full_width' %}section-full{% else %}page-width{% endif %} unset-width">
    <div
      class="{% if section.settings.title != blank %}section-head-top{% endif %} {{ section.settings.heading_position }}"
    >
      {%- if section.settings.title != blank -%}
        <h2
          class="section-head inline-richtext {{ section.settings.heading_size }} {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %} custom"
        >
          {{ section.settings.title }}
        </h2>
      {%- endif %}
      {%- if section.settings.view_label != blank -%}
        <div
          class="topc collection__view-all{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        >
          <a
            {% if section.settings.view_link == blank %}
              role="link" aria-disabled="true"
            {% else %}
              href="{{ section.settings.view_link }}"
            {% endif %}
            class="{% if section.settings.view_all_style == 'link' %}link underlined-link{% elsif section.settings.view_all_style == 'solid' %}button{% else %}button button--secondary{% endif %}"
            aria-label="{{ 'sections.featured_collection.view_all_label' | t }}"
          >
            <span>{{ section.settings.view_label }}</span>
          </a>
        </div>
      {%- endif -%}
    </div>

    <div
      class="grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
    >
      {%- for block in section.blocks -%}
        {%- liquid
          if block.settings.image_behavior == 'ambient'
            assign full_width = '120vw'
            assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
          else
            assign full_width = '100vw'
            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
          endif
        -%}
        <div
          class="banner--{{ section.settings.image_height }} block-{{ block.id }} grid__item banner banner--content-align-{{ block.settings.desktop_content_alignment }} banner--content-align-mobile-{{ block.settings.mobile_content_alignment }}"
        >
          {%- if block.settings.clickable_image and block.settings.clickable_image_link != blank -%}
            <a
              style="z-index: 100"
              class="full-image-link"
              href="{{ block.settings.clickable_image_link }}"
              title="{{ 'products.modal.label' | t }}"
            ></a>
          {%- endif -%}
          <div
            class="banner__media media{% if block.settings.image == blank %} placeholder{% endif %}{% if block.settings.image_behavior != 'none' %} animate--{{ block.settings.image_behavior }}{% endif %}"
          >
            {%- if block.settings.image != blank -%}
              {%- liquid
                assign image_height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                assign sizes = full_width
              -%}
              {{
                block.settings.image
                | image_url: width: 3840
                | image_tag:
                  loading: 'lazy',
                  width: block.settings.image.width,
                  height: image_height,
                  sizes: sizes,
                  widths: widths
              }}
            {% else %}
              {%- assign placeholder_slide = forloop.index | modulo: 2 -%}
              {%- if placeholder_slide == 1 -%}
                {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- else -%}
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if block.settings.subheading != blank
            or block.settings.heading != blank
            or block.settings.text != blank
            or block.settings.button_label != blank
          -%}
            <div class="{% if block.settings.overlay == true %} gallery-overlay {% endif %} banner__content banner__content--{{ block.settings.desktop_content_position }}">
              <div
                class="custom-banner__box banner__box color-{{ block.settings.color_scheme }} gradient {% if block.settings.content_bg == false %}bg-transparent{% endif %}"
              >
                {% if block.settings.subheading != blank %}
                  <div class="banner__subheading rte">
                    {{ block.settings.subheading }}
                  </div>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h2
                    class="banner__heading inline-richtext {{ block.settings.heading_size }} {% if block.settings.uppercase_head %}uppercase{% endif %}"
                    {{ block.shopify_attributes }}
                  >
                    {{ block.settings.heading }}
                  </h2>
                {% endif %}
                {% if block.settings.text != blank %}
                  <div class="banner__text rte {{ block.settings.text_style }}" {{ block.shopify_attributes }}>
                    {{ block.settings.text }}
                  </div>
                {% endif %}
                {%- if block.settings.button_label != blank -%}
                  <a
                    {% if block.settings.button_link == blank %}
                      role="link" aria-disabled="true"
                    {% else %}
                      href="{{ block.settings.button_link }}"
                    {% endif %}
                    class=" gallery_btn {% if block.settings.button_style == 'link' %}link underlined-link{% elsif block.settings.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}"
                  >
                    <span>{{- block.settings.button_label | escape -}}</span>
                  </a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- style -%}
            .gallery_img .block-{{ block.id }} .banner__box.color-{{ block.settings.color_scheme }} {
            background-color: rgba(var(--color-background),{{ block.settings.content_bg_opacity | divided_by: 100.0 }});
            }
            {% if section.settings.image_height == 'adapt' and block.settings.image != blank %}
            .gallery_img .block-{{ block.id }}.banner--adapt::before {
            content: '';
            padding-bottom: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}%;
            }
            {% endif %}
            {% if section.settings.image_height == 'adapt' and block.settings.image == blank %}
            .gallery_img .block-{{ block.id }}.banner--adapt::before {
            content: '';
            padding-bottom: 100%;
            }
            {% endif %}
            .gallery_btn{
              background-color: rgba(var(--color-button), var(--alpha-button-background));
            }
          {%- endstyle -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

