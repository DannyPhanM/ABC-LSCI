    <style>
    [custom-data-value='en'][show-icon]::before {
      content: '';
      background-image: url(https://cdn.shopify.com/s/files/1/0885/1446/2062/files/vietnam_flag.png?v=1732158721);
      background-size: cover;
      width: 36px;
      height: 24px;
      display: inline-block;
      min-width: 36px;
    }
    [custom-data-value='vi'][show-icon]::before {
      content: '';
      background-image: url(https://cdn.shopify.com/s/files/1/0885/1446/2062/files/uk_flag3x.png?v=1733208748);
      background-size: contain;
      width: 32px;
      height: 24px;
      display: inline-block;
      min-width: 32px;
    }

    #HeaderLanguageList a {
      display: flex;
      align-items: center;
      gap: 5px;
      line-height: 0.5 !important;
      justify-content: center;
    }
