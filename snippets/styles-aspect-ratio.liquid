{%- liquid
  assign classes_aspect_ratio = ''
  case mobile_aspect_ratio
    when 'original_ratio'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-auto '
    when '4:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-4/1 '
    when '3:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-3/1 '
    when '2:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-2/1 '
    when '16:9'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-16/9 '
    when '3:2'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-3/2 '
    when '4:3'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-4/3 '
    when '5:4'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-5/4 '
    when '1:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-1/1 '
    when '4:5'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-4/5 '
    when '3:4'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-3/4 '
    when '2:3'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-2/3 '
    when '9:16'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' aspect-9/16 '
  endcase

  case desktop_aspect_ratio
    when 'original_ratio'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-auto '
    when '4:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-4/1 '
    when '3:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-3/1 '
    when '2:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-2/1 '
    when '16:9'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-16/9 '
    when '3:2'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-3/2 '
    when '4:3'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-4/3 '
    when '5:4'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-5/4 '
    when '1:1'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-1/1 '
    when '4:5'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-4/5 '
    when '3:4'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-3/4 '
    when '2:3'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-2/3 '
    when '9:16'
      assign classes_aspect_ratio = classes_aspect_ratio | append: ' md:aspect-9/16 '
  endcase
-%}
{{- classes_aspect_ratio -}}
