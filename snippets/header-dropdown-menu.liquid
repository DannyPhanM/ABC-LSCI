<script>
  {% comment %} function checkAndApplyMargin() {
    let div = document.querySelector('sticky-header');
    let height = div.offsetHeight;
    console.log("height div: ", height);

    height = height - 60;

    console.log("height div after: ", height);

    const menu = document.querySelector('desktop-webi-menu');
    const menulist = document.querySelector('.main-menu');
    const submenus = document.querySelectorAll('.resize-header__submenu');

    const menuWidth = parseFloat(getComputedStyle(menu).width);
    const menulistWidth = parseFloat(getComputedStyle(menulist).width);

    const container = document.querySelector('.main-menu');

    submenus.forEach((submenu) => {
      submenu.style.marginTop = '30px';
    });

    if (menuWidth === menulistWidth) {
      submenus.forEach((submenu) => (submenu.style.marginTop = `${height}px`));
      const children = Array.from(container.children);

      const firstRowTop = children[0].getBoundingClientRect().top;
      console.log(firstRowTop, "firstRowTop");

      children.forEach((child) => {
        if (child.getBoundingClientRect().top > firstRowTop) {
          console.log(child.getBoundingClientRect().top, "nextRowTop");
          const collectionName = child.getAttribute('collection_tab');
          console.log(collectionName, "collectionName");

          submenus.forEach((submenu) => {
            if (submenu.getAttribute('collection_tab') === collectionName) {
              submenu.style.marginTop = '20px';
            }
          });
        }
      });
    }
  }

  document.addEventListener('DOMContentLoaded', checkAndApplyMargin); {% endcomment %}

  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      checkAndApplyMargin();
    }, 200); // Adjust delay as needed
  });
</script>
