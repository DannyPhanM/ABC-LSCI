                                  color: {{ block.settings.activetab_color }};
                                }
                              {%- endstyle -%}
                              <script>
                                function megaTab() {
                                  const tabs = document.querySelector('.mtab-{{ block.id }}');
                                  const tabButton = document.querySelectorAll('.mtab-{{ block.id }} .tab-button');
                                  const contents = document.querySelectorAll('.mtab-{{ block.id }} .tab-pane');
                                  tabs.onclick = (e) => {
                                    onTabclick(e);
                                  };
                                  tabs.addEventListener('keydown', (e) => {
                                    if (e.keyCode === 13) {
                                      onTabclick(e);
                                    }
                                  });

                                  function onTabclick(e) {
                                    const id = e.target.dataset.id;
                                    if (id) {
                                      tabButton.forEach((btn) => {
                                        btn.classList.remove('active');
                                      });
                                      e.target.classList.add('active');

                                      contents.forEach((content) => {
                                        content.classList.remove('active');
                                      });
                                      const element = document.getElementById(id);
                                      element.classList.add('active');
                                    }
                                  }
                                }
                                document.addEventListener('shopify:section:load', megaTab);
                                megaTab();
