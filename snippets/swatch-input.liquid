{% comment %}
  Renders a swatch input component.
  Accepts:
  - id: {String} unique input id
  - type: {String} input type. Accepts 'radio' or 'checkbox', defaults to 'radio' (optional)
  - name: {String} input name,
  - value: {ProductOptionValueDrop} input value
  - swatch: {SwatchDrop} the swatch drop
  - product_form_id: {String} id of the form associted with the input
  - checked: {Boolean} default checked status
  - disabled: {Boolean} default disabled status (optional)
  - visually_disabled: {Boolean} style the swatch as disabled, but leave the input enabled (optional)
  - shape: {String} swatch shape. Accepts 'square', defaults to circle (optional)
  - help_text: {String} additional content to render inside the label (optional)

  Usage:
   {% render 'swatch-input',
      id: input_id,
      name: input_name,
      value: input_value,
      swatch: swatch,
      product_form_id: product_form_id,
      checked: checked
    %}
{% endcomment %}

<input
  type="{{ type | default: 'radio' }}"
  id="{{ id }}"
  name="{{ name }}"
  value="{{ value }}"
  aria-label="{{ value | escape }}"
  form="{{ product_form_id }}"
  class="swatch-input__input{% if visually_disabled %} disabled{% endif %}"
  {% if checked %}
    checked
  {% endif %}
  {% if disabled %}
    disabled
  {% endif %}
>
{% unless pswatch_type == 'pswatch_image' or pswatch_type == 'pswatch_text' %}
<label
  for="{{ id }}"
  title="{{ value }}"
  value="{{ value }}"
  data-value="{{ value }}"
  class="swatch-input__label"
>
  {% render 'swatch', swatch: swatch, shape: shape %}
  {{ help_text }}
</label>
{% endunless %}

{% if pswatch_type == 'pswatch_image' %}
  {%- liquid
    for variant in product.variants
      if variant.title contains value
        if variant.image.src
          assign variantImgSrc = variant.image.src | image_url: width: 40, crop: 'center'
        else
          assign variantImgSrc = "Invaild"
        endif
        break
      endif
    endfor
    assign colorswatchvalue = value | downcase | replace: ' ', ''
  -%}
  <label for="{{ id }}" class="pswatch_image {% if option.selected_value == value %}active{% endif %}" {% if option.selected_value == value %} tabindex="0" {% endif %}
    data-value="{{ value }}" style="{% if variantImgSrc != 'Invaild' %}background-image: url({{ variantImgSrc }});{% else %} background-color: {{ colorswatchvalue }};{% endif %}">
    {{ value -}}
    <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
  </label>
{% elsif pswatch_type == 'pswatch_text' %}
  <label for="{{ id }}" class="{% if pills_style == 'fill' %}fillpill{% endif %} {% if option.selected_value == value %}active{% endif %}" {% if option.selected_value == value %} tabindex="0" {% endif %} data-value="{{ value }}">
    {{ value -}}
    <span class="visually-hidden">{{ 'products.product.variant_sold_out_or_unavailable' | t }}</span>
  </label>
{% endif %}