                                    option: option,
                                    block: block,
                                    name: option.name,
                                    swatch: value.swatch,
                                    product_form_id: product_form_id,
                                    checked: checked,
                                    help_text: help_text,
                                    show_colorswatch: settings.show_colorswatch,
                                    picker_type: spicker_type
                                  %}
                                </div>
                              </div>
                            </fieldset>

                          {%- elsif picker_type == 'button' -%}
                            <fieldset class="js product_form_input product-form__input">
                              <div class="">
                                <legend class="form__label">{{ option.name }}</legend>
                                <div
                                  {% if option.name == 'Color' and show_colorswatch == true %}
                                    class="wbswatchclr"
                                  {% endif %}
