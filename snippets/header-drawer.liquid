                                                      {% assign limit = block.settings.columns_desktop %}
                                                      {%- for i in (1..limit) -%}
                                                        <div
                                                          class="grid__item collection-list__item"
                                                          {{ block.shopify_attributes }}
                                                        >
                                                          {%- assign placeholder_image_index = forloop.index0
                                                            | modulo: 4
                                                            | plus: 1
                                                          -%}
                                                          {%- assign placeholder_image = 'collection-apparel-'
                                                            | append: placeholder_image_index
                                                          -%}
                                                          {% render 'card-collection',
                                                            columns: columns,
                                                            collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                            placeholder_image: placeholder_image
                                                          %}
                                                        </div>
                                                      {%- endfor -%}
                                                    {%- endfor -%}
                                                  </div>
                                                </div>
                                              {%- endif -%}
                                            </div>
                                          </div>
                                          {%- style -%}
                                            .mtab-mobile-{{ block.id }} .tabs-collapse span.active, .mtab-mobile-{{ block.id }} .tabs-collapse span:hover {
                                              color: {{ block.settings.activetab_color }};
                                            }
                                          {%- endstyle -%}
                                          <script>
                                            function megaTab() {
                                              const tabs = document.querySelector('.mtab-mobile-{{ block.id }}');
                                              const tabButton = document.querySelectorAll(
                                                '.mtab-mobile-{{ block.id }} .tab-button'
                                              );
                                              const contents = document.querySelectorAll(
                                                '.mtab-mobile-{{ block.id }} .tab-pane'
                                              );
                                              tabs.onclick = (e) => {
                                                onTabclick(e);
                                              };
                                              tabs.addEventListener('keydown', (e) => {
                                                if (e.keyCode === 13) {
                                                  onTabclick(e);
                                                }
                                              });

                                              function onTabclick(e) {
                                                const id = e.target.dataset.id;
                                                if (id) {
                                                  tabButton.forEach((btn) => {
                                                    btn.classList.remove('active');
                                                  });
                                                  e.target.classList.add('active');

                                                  contents.forEach((content) => {
                                                    content.classList.remove('active');
                                                  });
                                                  const element = document.getElementById(id);
                                                  element.classList.add('active');
                                                }
                                              }
                                            }
                                            document.addEventListener('shopify:section:load', megaTab);
                                            megaTab();
                                          </script>
                                        {% endif %}

                                      {% when 'mega-menu-tabinfo' %}
                                        <div class="mega-menu-tabinfo grid">
                                          <div class="grid__item tabinfo_left">
                                            {%- if block.settings.coll_headingleft != blank -%}
                                              <h3 class="info_heading">{{ block.settings.coll_headingleft }}</h3>
                                            {%- endif -%}
                                            <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                              {%- for collection in block.settings.info_coll -%}
                                                <div
                                                  class="grid__item collection-list__item"
                                                  {{ block.shopify_attributes }}
                                                >
                                                  {%- assign placeholder_image_index = forloop.index0
                                                    | modulo: 4
                                                    | plus: 1
                                                  -%}
                                                  {%- assign placeholder_image = 'collection-apparel-'
                                                    | append: placeholder_image_index
                                                  -%}
                                                  {% render 'card-collection',
                                                    card_collection: collection,
                                                    media_aspect_ratio: block.settings.image_ratio,
                                                    coll_card_style: block.settings.infocall_card_style,
                                                    collection_card_text_alignment: block.settings.infocall_alignment,
                                                    collection_card_color_scheme: block.settings.infocall_color_scheme,
                                                    columns: columns,
                                                    placeholder_image: placeholder_image
                                                  %}
                                                </div>
                                              {%- else -%}
                                                {% assign limit = block.settings.columns_desktop %}
                                                {%- for i in (1..limit) -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      columns: columns,
                                                      collection_card_text_alignment: block.settings.infocall_alignment,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- endfor -%}
                                              {%- endfor -%}
                                            </div>
                                          </div>
                                          <div class="grid__item tabinfo_right cinfo-{{ block.id }}">
                                            <div>
                                              {%- if block.settings.info_heading != blank -%}
                                                <h3 class="info_heading">{{ block.settings.info_heading }}</h3>
                                              {%- endif -%}

                                              <ul class="tabinfo_ul">
                                                {%- if block.settings.info_text1 != blank -%}
                                                  <li>
                                                    {%- if block.settings.info_icon1 != 'none' -%}
                                                      <span class="tabinfo_svg">
                                                        {%- render 'icon-accordion', icon: block.settings.info_icon1 -%}
                                                      </span>
                                                    {%- endif -%}
                                                    <span>{{ block.settings.info_text1 }}</span>
                                                  </li>
                                                {%- endif -%}

                                                {%- if block.settings.info_text2 != blank -%}
                                                  <li>
                                                    {%- if block.settings.info_icon2 != 'none' -%}
                                                      <span class="tabinfo_svg">
                                                        {%- render 'icon-accordion', icon: block.settings.info_icon2 -%}
                                                      </span>
                                                    {%- endif -%}
                                                    <span>{{ block.settings.info_text2 }}</span>
                                                  </li>
                                                {%- endif -%}

                                                {%- if block.settings.info_text3 != blank -%}
                                                  <li>
                                                    {%- if block.settings.info_icon3 != 'none' -%}
                                                      <span class="tabinfo_svg">
                                                        {%- render 'icon-accordion', icon: block.settings.info_icon3 -%}
                                                      </span>
                                                    {%- endif -%}
                                                    <span>{{ block.settings.info_text3 }}</span>
                                                  </li>
                                                {%- endif -%}

                                                {%- if block.settings.info_text4 != blank -%}
                                                  <li>
                                                    {%- if block.settings.info_icon4 != 'none' -%}
                                                      <span class="tabinfo_svg">
                                                        {%- render 'icon-accordion', icon: block.settings.info_icon4 -%}
                                                      </span>
                                                    {%- endif -%}
                                                    <span>{{ block.settings.info_text4 }}</span>
                                                  </li>
                                                {%- endif -%}
                                              </ul>
                                            </div>
                                            <div class="tabinfo_bottom">
                                              {%- if block.settings.info_heading2 != blank -%}
                                                <h3 class="info_heading">{{ block.settings.info_heading2 }}</h3>
                                              {%- endif -%}
                                              {%- if block.settings.fcontactno != blank -%}
                                                <div class="info_contact">
                                                  <a href="tel:{{ block.settings.fcontactno }}">
                                                    {%- render 'icon-call' -%}
                                                    <span>{{ block.settings.fcontactno }}</span></a
                                                  >
                                                </div>
                                              {%- endif -%}
                                              {%- if block.settings.fcontactid != blank -%}
                                                <div class="info_mail">
                                                  <a href="mailto:{{ block.settings.fcontactid }}">
                                                    {%- render 'icon-envelope' -%}
                                                    <span>{{ block.settings.fcontactid }}</span></a
                                                  >
                                                </div>
                                              {%- endif -%}
                                            </div>
                                          </div>

                                          {%- style -%}
                                            .cinfo-{{ block.id }} .tabinfo_svg {
                                              background: {{ block.settings.icon_bgcolor }};
                                              color: {{ block.settings.icon_textcolor }};
                                            }
                                            .cinfo-{{ block.id }} .tabinfo_svg svg {
                                              fill: {{ block.settings.icon_textcolor }};
                                            }
                                            .cinfo-{{ block.id }} .tabinfo_bottom .info_mail svg, .cinfo-{{ block.id }} .tabinfo_svg svg.stroke_color {
                                              fill: none;
                                            }
                                            .cinfo-{{ block.id }} .tabinfo_svg svg.stroke_color path {
                                              stroke: {{ block.settings.icon_textcolor }};
                                            }
                                            .cinfo-{{ block.id }} .tabinfo_bottom svg {
                                              fill: {{ block.settings.icon_bottomcolor }};
                                            }
                                            .cinfo-{{ block.id }} .tabinfo_bottom .info_mail svg {
                                              stroke: {{ block.settings.icon_bottomcolor }};
                                            }
                                          {%- endstyle -%}
                                        </div>
                                    {%- endcase -%}
                                  {%- endif -%}
                                {%- endfor -%}
                              </div>
                            {%- endif -%}
                          </div>
                        </div>
                      </details>
                    {% else %}
                      <a
                        id="HeaderDrawer-{{ link.handle }}"
                        href="{{ link.url }}"
                        class="{{ high_title_color }} menu-drawer__menu-item list-menu__item link focus-inset{% if link.current %} menu-drawer__menu-item--active{% endif %}{% if uppercase_menu %} uppercase{% endif %}"
                        {% if link.current %}
                          aria-current="page"
                        {% endif %}
                      >
                        {%- if hlink_icon -%}{% render 'icon-highlight-star' %}{%- endif -%}
                        <span>{{ link.title | escape }}</span>
                        {%- if hlink_icon -%}{% render 'icon-highlight-star' %}{%- endif -%}
                      </a>
                    {%- endif -%}
                  {%- endif -%}
                </li>
                {%- style -%}
                  #HeaderDrawer-{{ link.handle }}.high_link {
                    color: {{ hlink_color }} !important;
                  }
                  #HeaderDrawer-{{ link.handle }}.high_link * {
                    color: {{ hlink_color }} !important;
                  }
                  #HeaderDrawer-{{ link.handle }}.high_link .header_iconshine {
                    fill: {{ hlink_color }};
                  }
                {%- endstyle -%}
              {%- endfor -%}
            </ul>
          </nav>

          {%- liquid
            assign has_social_icons = true
            if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
              assign has_social_icons = false
            endif
          -%}

          {%- if second_menu != blank
            or enable_country_selector
            or enable_language_selector
            or show_social
            and has_social_icons
          -%}
            <div class="menu-drawer__utility-links">
              <div class="second_menu">
                <div class="second_menu_inner">
                  {%- if second_menu != blank -%}
                    <div class="smenu_left">
                      <ul class="list-menu list-menu--inline">
                        {{ second_menu }}
                      </ul>
                    </div>
                  {%- endif -%}

                  {%- if enable_country_selector or enable_language_selector or show_social and has_social_icons -%}
                    <div class="smenu_right">
                      {%- if show_social and has_social_icons -%}
                        <div>
                          {%- render 'social-icons', social_style: block.settings.social_style -%}
                        </div>
                      {%- endif -%}

                      {%- if enable_country_selector or enable_language_selector -%}
                        <div class="menu-drawer__localization header-localization">
                          {%- if enable_country_selector and localization.available_countries.size > 1 -%}
                            <localization-form>
                              {%- form 'localization', id: 'HeaderCountryMobileForm', class: 'localization-form' -%}
                                <div>
                                  <h2 class="visually-hidden" id="HeaderCountryMobileLabel">
                                    {{ 'localization.country_label' | t }}
                                  </h2>
                                  {%- render 'country-localization', localPosition: 'HeaderCountryMobile' -%}
                                </div>
                              {%- endform -%}
                            </localization-form>
                          {% endif %}

                          {%- if enable_language_selector and localization.available_languages.size > 1 -%}
                            <localization-form>
                              {%- form 'localization', id: 'HeaderLanguageMobileForm', class: 'localization-form' -%}
                                <div>
                                  <h2 class="visually-hidden" id="HeaderLanguageMobileLabel">
                                    {{ 'localization.language_label' | t }}
                                  </h2>
                                  {%- render 'language-localization', localPosition: 'HeaderLanguageMobile' -%}
                                </div>
                              {%- endform -%}
                            </localization-form>
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </details>
</header-drawer>
