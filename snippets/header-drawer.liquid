{% comment %}
  Renders a header drawer menu for mobile and desktop.

  Usage:
  {% render 'header-drawer' %}
{% endcomment %}
{%- if settings.enable_quick_add or settings.quick_view_button -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag: preload: true }}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}
<header-drawer data-breakpoint="{% if section.settings.menu_type_desktop == 'drawer' %}desktop{% else %}tablet{% endif %}">
  <details id="Details-menu-drawer-container" class="menu-drawer-container">
    <summary
      class="header__icon header__icon--menu header__icon--summary link focus-inset"
      aria-label="{{ 'sections.header.menu' | t }}"
    >
      <span>
        {% render 'icon-hamburger' %}
        {% render 'icon-close' %}
      </span>
    </summary>
    <div id="menu-drawer" class="gradient menu-drawer motion-reduce color-{{ section.settings.menu_color_scheme }}">
      <div class="menu-drawer__inner-container">
        <div class="menu-drawer__navigation-container">
          <nav class="menu-drawer__navigation">
            <ul class="menu-drawer__menu has-submenu list-menu" role="list">
              {%- for link in section.settings.menu.links -%}
                {%- liquid
                  assign contain_mega = false
                  assign hlink_icon = false
                  assign high_title_color = ''
                  for block in blocks
                    assign menublock_lower = block.settings.menu_title | downcase
                    assign linkblock_lower = link.title | downcase
                    assign high_title = block.settings.highlight_title | downcase

                    if linkblock_lower == high_title
                      assign high_title_color = 'high_link'
                      assign hlink_icon = block.settings.hlink_icon
                      assign hlink_color = block.settings.hlink_color
                    endif

                    if linkblock_lower == menublock_lower
                      assign contain_mega = true
                    endif
                  endfor
                -%}
                <li>
                  {%- if link.links != blank -%}
                    <details id="Details-menu-drawer-menu-item-{{ forloop.index }}">
                      <summary
                        id="HeaderDrawer-{{ link.handle }}"
                        class="{{ high_title_color }} menu-drawer__menu-item list-menu__item link focus-inset{% if link.child_active %} menu-drawer__menu-item--active{% endif %}{% if uppercase_menu %} uppercase{% endif %}"
                      >
                        {%- if hlink_icon -%}{% render 'icon-highlight-star' %}{%- endif -%}
                        <a href="{{link.url}}">{{ link.title | escape }}</a>
                        {%- if hlink_icon -%}{% render 'icon-highlight-star' %}{%- endif -%}
                        {% render 'icon-arrow' %}
                        {% comment %} {% render 'icon-caret' %} {% endcomment %}
                      </summary>
                      <div
                        id="link-{{ link.handle | escape }}"
                        class="menu-drawer__submenu has-submenu gradient motion-reduce"
                        tabindex="-1"
                      >
                        <div class="menu-drawer__inner-submenu">
                          <button class="menu-drawer__close-button link focus-inset" aria-expanded="true">
                            {% render 'icon-arrow' %}
                            {{ link.title | escape }}
                          </button>
                          <ul class="menu-drawer__menu list-menu" role="list" tabindex="-1">
                            {%- for childlink in link.links -%}
                              <li>
                                {%- if childlink.links == blank -%}
                                  <a
                                    id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                    href="{{ childlink.url }}"
                                    class="menu-drawer__menu-item link list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                    {% if childlink.current %}
                                      aria-current="page"
                                    {% endif %}
                                  >
                                    {{ childlink.title | escape }}
                                  </a>
                                {%- else -%}
                                  <details id="Details-menu-drawer-{{ link.handle }}-{{ childlink.handle }}">
                                    <summary
                                      id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                      class="menu-drawer__menu-item link list-menu__item focus-inset"
                                    >
                                      <a
                                        id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}"
                                        href="{{ childlink.url }}"
                                        class=" list-menu__item focus-inset{% if childlink.current %} menu-drawer__menu-item--active{% endif %}"
                                        {% if childlink.current %}
                                          aria-current="page"
                                        {% endif %}
                                      >
                                        {{ childlink.title | escape }}
                                      </a>
                                      {% render 'icon-arrow' %}
                                      {% comment %} {% render 'icon-caret' %} {% endcomment %}
                                    </summary>
                                    <div
                                      id="childlink-{{ childlink.handle | escape }}"
                                      class="menu-drawer__submenu has-submenu gradient motion-reduce"
                                    >
                                      <button class="menu-drawer__close-button link focus-inset" aria-expanded="true">
                                        {% render 'icon-arrow' %}
                                        {{ childlink.title | escape }}
                                      </button>
                                      <ul
                                        class="menu-drawer__menu list-menu"
                                        role="list"
                                        tabindex="-1"
                                      >
                                        {%- for grandchildlink in childlink.links -%}
                                          <li>
                                            <a
                                              id="HeaderDrawer-{{ link.handle }}-{{ childlink.handle }}-{{ grandchildlink.handle }}"
                                              href="{{ grandchildlink.url }}"
                                              class="menu-drawer__menu-item link list-menu__item focus-inset{% if grandchildlink.current %} menu-drawer__menu-item--active{% endif %}"
                                              {% if grandchildlink.current %}
                                                aria-current="page"
                                              {% endif %}
                                            >
                                              {{ grandchildlink.title | escape }}
                                            </a>
                                          </li>
                                        {%- endfor -%}
                                      </ul>
                                    </div>
                                  </details>
                                {%- endif -%}
                              </li>
                            {%- endfor -%}
                          </ul>

                          {%- if contain_mega -%}
                            <div class="m_banner_right">
                              {%- for block in blocks -%}
                                {%- liquid
                                  assign menublock = block.settings.menu_title | downcase
                                  assign linkblock = link.title | downcase
                                -%}
                                {%- if linkblock == menublock -%}
                                  {%- case block.type -%}
                                    {% when 'mega-menu-banner' %}
                                      <div
                                        class="center mega_banner {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                                        {% if settings.animations_reveal_on_scroll %}
                                          data-cascade
                                          style="--animation-order: {{ forloop.index }};"
                                        {% endif %}
                                      >
                                        <div class="banner--{{ block.settings.banner_height }} banner">
                                          <div
                                            class="banner__media media{% if block.settings.banner_image == blank %} placeholder{% endif %}"
                                            {% if block.settings.banner_height == 'adapt'
                                              and block.settings.banner_image != blank
                                            %}
                                              style="padding-bottom: {{ 1 | divided_by: block.settings.banner_image.aspect_ratio | times: 100 }}%;"
                                            {% endif %}
                                            {% if block.settings.banner_height == 'adapt'
                                              and block.settings.banner_image == blank
                                            %}
                                              style="padding-bottom: 100%;"
                                            {% endif %}
                                          >
                                            {%- if block.settings.banner_image != blank -%}
                                              {%- liquid
                                                assign banner_height = block.settings.banner_image.width | divided_by: block.settings.banner_image.aspect_ratio | round
                                              -%}
                                              {{
                                                block.settings.banner_image
                                                | image_url: width: 3840
                                                | image_tag:
                                                  loading: 'lazy',
                                                  width: block.settings.banner_image.width,
                                                  height: banner_height,
                                                  sizes: '100vw',
                                                  widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                                              }}
                                            {% else %}
                                              {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                            {%- endif -%}
                                          </div>
                                        </div>
                                        {% if block.settings.heading != blank %}
                                          <h3 class="inline-richtext" {{ section.shopify_attributes }}>
                                            {{ block.settings.heading }}
                                          </h3>
                                        {% endif %}
                                        {%- if block.settings.button_label != blank -%}
                                          <a
                                            {% if block.settings.button_link == blank %}
                                              role="link" aria-disabled="true"
                                            {% else %}
                                              href="{{ block.settings.button_link }}"
                                            {% endif %}
                                            class="menu_banner_btn {% if block.settings.button_style == 'link' %}link underlined-link{% elsif block.settings.button_style == 'solid' %}button button--primary{% else %}button button--secondary{% endif %}"
                                          >
                                            <span>
                                              {{- block.settings.button_label | escape -}}
                                              {%- render 'icon-arrow' -%}
                                            </span>
                                          </a>
                                        {%- endif -%}
                                      </div>
                                  {%- endcase -%}
                                {%- endif -%}
                              {%- endfor -%}
                            </div>
                          {%- endif -%}

                          {%- if contain_mega -%}
                            <div class="page-width">
                              {%- for block in blocks -%}
                                {%- liquid
                                  assign menublock = block.settings.menu_title | downcase
                                  assign linkblock = link.title | downcase
                                -%}
                                {%- if linkblock == menublock -%}
                                  {%- case block.type -%}
                                    {% when 'mega-menu-product' %}
                                      <ul
                                        class="mega-menu-product grid grid--{{ block.settings.products_to_show }}-col-desktop"
                                        role="list"
                                        aria-label="{{ 'general.slider.name' | t }}"
                                      >
                                        {%- for product in block.settings.collection.products
                                          limit: block.settings.products_to_show
                                        -%}
                                          <li
                                            class="grid__item {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                                            {% if settings.animations_reveal_on_scroll %}
                                              data-cascade
                                              style="--animation-order: {{ forloop.index }};"
                                            {% endif %}
                                          >
                                            {% render 'card-product',
                                              card_product: product,
                                              card_style: settings.card_style,
                                              media_aspect_ratio: settings.image_ratio,
                                              show_secondary_image: settings.show_secondary_image,
                                              show_vendor: settings.show_cardvendor,
                                              section_id: section.id
                                            %}
                                          </li>
                                        {%- endfor -%}
                                      </ul>

                                    {% when 'mega-menu-tabcollections' %}
                                      <div class="mega-menu-collections megamenu_tabcoll mtab-mobile-{{ block.id }}">
                                        <div class="tabs-collapse">
                                          {%- if block.settings.tab1 != blank -%}
                                            <span
                                              class="tab-button active"
                                              tabindex="0"
                                              data-id="{{ block.id }}-1mobile"
                                            >
                                              {{- block.settings.tab1 -}}
                                            </span>
                                          {%- endif -%}

                                          {%- if block.settings.tab2 != blank -%}
                                            <span
                                              class="tab-button {% if block.settings.tab1 == blank %}active{% endif %}"
                                              tabindex="0"
                                              data-id="{{ block.id }}-2mobile"
                                            >
                                              {{- block.settings.tab2 -}}
                                            </span>
                                          {%- endif -%}

                                          {%- if block.settings.tab3 != blank -%}
                                            <span
                                              class="tab-button {% if block.settings.tab1 == blank and block.settings.tab2 == blank %}active{% endif %}"
                                              tabindex="0"
                                              data-id="{{ block.id }}-3mobile"
                                            >
                                              {{- block.settings.tab3 -}}
                                            </span>
                                          {%- endif -%}

                                          {%- if block.settings.tab4 != blank -%}
                                            <span
                                              class="tab-button {% if block.settings.tab1 == blank and block.settings.tab2 == blank and block.settings.tab3 == blank %}active{% endif %}"
                                              tabindex="0"
                                              data-id="{{ block.id }}-4mobile"
                                            >
                                              {{- block.settings.tab4 -}}
                                            </span>
                                          {%- endif -%}

                                          {%- if block.settings.tab5 != blank -%}
                                            <span
                                              class="tab-button {% if block.settings.tab1 == blank and block.settings.tab2 == blank and block.settings.tab3 == blank and block.settings.tab4 == blank %}active{% endif %}"
                                              tabindex="0"
                                              data-id="{{ block.id }}-5mobile"
                                            >
                                              {{- block.settings.tab5 -}}
                                            </span>
                                          {%- endif -%}
                                        </div>
                                        <div class="tab-content">
                                          {%- if block.settings.tab1 != blank -%}
                                            <div id="{{ block.id }}-1mobile" class="tab-pane fade active" tabindex="-1">
                                              <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                                {%- for collection in block.settings.coll1 -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      card_collection: collection,
                                                      media_aspect_ratio: block.settings.image_ratio,
                                                      coll_card_style: block.settings.collection_card_style,
                                                      collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                      collection_card_color_scheme: block.settings.collection_card_color_scheme,
                                                      columns: columns,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- else -%}
                                                  {% comment %}
                                                    {% assign limit = block.settings.columns_desktop %}
                                                    {%- for i in (1..limit) -%}
                                                      <div class="grid__item collection-list__item" {{ block.shopify_attributes }}>
                                                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                                                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                                                        {% render 'card-collection',
                                                          columns: columns,
                                                          collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                          placeholder_image: placeholder_image
                                                        %}
                                                      </div>
                                                    {%- endfor -%}
                                                  {% endcomment %}
                                                {%- endfor -%}
                                              </div>
                                            </div>
                                          {%- endif -%}
                                          {%- if block.settings.tab2 != blank -%}
                                            <div
                                              id="{{ block.id }}-2mobile"
                                              class="tab-pane fade {% if block.settings.tab1 == blank %}active{% endif %}"
                                              tabindex="-1"
                                            >
                                              <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                                {%- for collection in block.settings.coll2 -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      card_collection: collection,
                                                      media_aspect_ratio: block.settings.image_ratio,
                                                      coll_card_style: block.settings.collection_card_style,
                                                      collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                      collection_card_color_scheme: block.settings.collection_card_color_scheme,
                                                      columns: columns,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- else -%}
                                                  {% comment %}
                                                    {% assign limit = block.settings.columns_desktop %}
                                                    {%- for i in (1..limit) -%}
                                                      <div class="grid__item collection-list__item" {{ block.shopify_attributes }}>
                                                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                                                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                                                        {% render 'card-collection',
                                                          columns: columns,
                                                          collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                          placeholder_image: placeholder_image
                                                        %}
                                                      </div>
                                                    {%- endfor -%}
                                                  {% endcomment %}
                                                {%- endfor -%}
                                              </div>
                                            </div>
                                          {%- endif -%}

                                          {%- if block.settings.tab3 != blank -%}
                                            <div
                                              id="{{ block.id }}-3mobile"
                                              class="tab-pane fade {% if block.settings.tab1 == blank and block.settings.tab2 == blank %}active{% endif %}"
                                              tabindex="-1"
                                            >
                                              <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                                {%- for collection in block.settings.coll3 -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      card_collection: collection,
                                                      media_aspect_ratio: block.settings.image_ratio,
                                                      coll_card_style: block.settings.collection_card_style,
                                                      collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                      collection_card_color_scheme: block.settings.collection_card_color_scheme,
                                                      columns: columns,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- else -%}
                                                  {% comment %}
                                                    {% assign limit = block.settings.columns_desktop %}
                                                    {%- for i in (1..limit) -%}
                                                      <div class="grid__item collection-list__item" {{ block.shopify_attributes }}>
                                                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                                                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                                                        {% render 'card-collection',
                                                          columns: columns,
                                                          collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                          placeholder_image: placeholder_image
                                                        %}
                                                      </div>
                                                    {%- endfor -%}
                                                  {% endcomment %}
                                                {%- endfor -%}
                                              </div>
                                            </div>
                                          {%- endif -%}

                                          {%- if block.settings.tab4 != blank -%}
                                            <div
                                              id="{{ block.id }}-4mobile"
                                              class="tab-pane fade {% if block.settings.tab1 == blank and block.settings.tab2 == blank and block.settings.tab3 == blank %}active{% endif %}"
                                              tabindex="-1"
                                            >
                                              <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                                {%- for collection in block.settings.coll4 -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      card_collection: collection,
                                                      media_aspect_ratio: block.settings.image_ratio,
                                                      coll_card_style: block.settings.collection_card_style,
                                                      collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                      collection_card_color_scheme: block.settings.collection_card_color_scheme,
                                                      columns: columns,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- else -%}
                                                  {% comment %}
                                                    {% assign limit = block.settings.columns_desktop %}
                                                    {%- for i in (1..limit) -%}
                                                      <div class="grid__item collection-list__item" {{ block.shopify_attributes }}>
                                                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                                                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                                                        {% render 'card-collection',
                                                          columns: columns,
                                                          collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                          placeholder_image: placeholder_image
                                                        %}
                                                      </div>
                                                    {%- endfor -%}
                                                  {% endcomment %}
                                                {%- endfor -%}
                                              </div>
                                            </div>
                                          {%- endif -%}

                                          {%- if block.settings.tab5 != blank -%}
                                            <div
                                              id="{{ block.id }}-5mobile"
                                              class="tab-pane fade {% if block.settings.tab1 == blank and block.settings.tab2 == blank and block.settings.tab3 == blank and block.settings.tab4 == blank %}active{% endif %}"
                                              tabindex="-1"
                                            >
                                              <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                                {%- for collection in block.settings.coll5 -%}
                                                  <div
                                                    class="grid__item collection-list__item"
                                                    {{ block.shopify_attributes }}
                                                  >
                                                    {%- assign placeholder_image_index = forloop.index0
                                                      | modulo: 4
                                                      | plus: 1
                                                    -%}
                                                    {%- assign placeholder_image = 'collection-apparel-'
                                                      | append: placeholder_image_index
                                                    -%}
                                                    {% render 'card-collection',
                                                      card_collection: collection,
                                                      media_aspect_ratio: block.settings.image_ratio,
                                                      coll_card_style: block.settings.collection_card_style,
                                                      collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                      collection_card_color_scheme: block.settings.collection_card_color_scheme,
                                                      columns: columns,
                                                      placeholder_image: placeholder_image
                                                    %}
                                                  </div>
                                                {%- else -%}
                                                  {% comment %}
                                                    {% assign limit = block.settings.columns_desktop %}
                                                    {%- for i in (1..limit) -%}
                                                      <div class="grid__item collection-list__item" {{ block.shopify_attributes }}>
                                                        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                                                        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                                                        {% render 'card-collection',
                                                          columns: columns,
                                                          collection_card_text_alignment: block.settings.collection_card_text_alignment,
                                                          placeholder_image: placeholder_image
                                                        %}
                                                      </div>
                                                    {%- endfor -%}
                                                  {% endcomment %}
                                                {%- endfor -%}
                                              </div>
                                            </div>
                                          {%- endif -%}
                                        </div>
                                      </div>
                                      {%- style -%}
                                        .mtab-mobile-{{ block.id }} .tabs-collapse span.active, .mtab-mobile-{{ block.id }} .tabs-collapse span:hover {
                                          color: {{ block.settings.activetab_color }};
                                        }
                                      {%- endstyle -%}
                                      <script>
                                        function megaTab() {
                                          const tabs = document.querySelector('.mtab-mobile-{{ block.id }}');
                                          const tabButton = document.querySelectorAll(
                                            '.mtab-mobile-{{ block.id }} .tab-button'
                                          );
                                          const contents = document.querySelectorAll(
                                            '.mtab-mobile-{{ block.id }} .tab-pane'
                                          );
                                          tabs.onclick = (e) => {
                                            onTabclick(e);
                                          };
                                          tabs.addEventListener('keydown', (e) => {
                                            if (e.keyCode === 13) {
                                              onTabclick(e);
                                            }
                                          });

                                          function onTabclick(e) {
                                            const id = e.target.dataset.id;
                                            if (id) {
                                              tabButton.forEach((btn) => {
                                                btn.classList.remove('active');
                                              });
                                              e.target.classList.add('active');

                                              contents.forEach((content) => {
                                                content.classList.remove('active');
                                              });
                                              const element = document.getElementById(id);
                                              element.classList.add('active');
                                            }
                                          }
                                        }
                                        document.addEventListener('shopify:section:load', megaTab);
                                        megaTab();
                                      </script>

                                    {% when 'mega-menu-tabinfo' %}
                                      <div class="mega-menu-tabinfo grid">
                                        <div class="grid__item tabinfo_left">
                                          {%- if block.settings.coll_headingleft != blank -%}
                                            <h3 class="info_heading">{{ block.settings.coll_headingleft }}</h3>
                                          {%- endif -%}
                                          <div class="grid grid--{{ block.settings.columns_desktop }}-col-desktop">
                                            {%- for collection in block.settings.info_coll -%}
                                              <div
                                                class="grid__item collection-list__item"
                                                {{ block.shopify_attributes }}
                                              >
                                                {%- assign placeholder_image_index = forloop.index0
                                                  | modulo: 4
                                                  | plus: 1
                                                -%}
                                                {%- assign placeholder_image = 'collection-apparel-'
                                                  | append: placeholder_image_index
                                                -%}
                                                {% render 'card-collection',
                                                  card_collection: collection,
                                                  media_aspect_ratio: block.settings.image_ratio,
                                                  coll_card_style: block.settings.infocall_card_style,
